---
import { Image, inferRemoteSize } from "astro:assets";

const {
  imageUrl,
  altText = "",
  title,
  description,
  buttonLabel = "Ver Categoría",
  buttonHref = "#",
  position = "left",
} = Astro.props;

// Obtener dimensiones automáticamente - funciona para imágenes remotas y locales
let width, height;

// Si es una imagen local de Astro (objeto con src), usar dimensiones por defecto
if (typeof imageUrl === 'object' && imageUrl.src) {
  width = imageUrl.width || 700;
  height = imageUrl.height || 450;
} else {
  // Si es una URL remota, usar inferRemoteSize
  try {
    const dimensions = await inferRemoteSize(imageUrl);
    width = dimensions.width;
    height = dimensions.height;
  } catch (error) {
    // Fallback en caso de error
    width = 700;
    height = 450;
  }
}
---

<!-- Contenedor principal -->
<div class="mx-auto max-w-6xl px-4 py-6 font-fuenteprincipal">
  <!-- Usamos flex-col por defecto (móvil) y flex-row en md (pantallas medianas) -->
  <div class="flex flex-col md:flex-row items-stretch h-max">
    <!-- Imagen -->
    <div
      class={`
          w-full md:w-1/2 h-auto   
          ${position === "right" ? "md:order-2" : "md:order-1"}
          order-1  /* Por defecto, en móvil, va debajo del texto */
        `}
    >
      <Image 
        src={typeof imageUrl === 'object' && imageUrl.src ? imageUrl : imageUrl} 
        alt={altText || `Imagen de ${title || 'Categoría'}`}
        width={width}
        height={height}
        format="webp"
        class="w-full h-full object-cover" 
      />
    </div>

    <!-- Texto y botón -->
    <div
      class={`
          w-full md:w-1/2 bg-gray-300 h-auto flex flex-col justify-between  items-start
          ${position === "right" ? "md:order-1" : "md:order-2"}
          order-2  /* Por defecto, en móvil, va encima de la imagen */
          md:mt-0 p-6 md:p-8
        `}
    >
      <h2
        class="text-xl md:text-3xl lg:text-4xl text-azulsecundario font-regular mb-2"
      >
        <span class="font-bold">{title}</span>
      </h2>
      {description && (
        <p class="mb-4 text-lg md:text-xl lg:text-2xl text-azulsecundario">
          {description}
        </p>
      )}
      {buttonHref && (
        <a
          href={buttonHref}
          class="inline-flex items-center bg-azulprimario text-white text-xl md:text-lg lg:text-2xl px-10 py-5 md:px-8 md:py-4 lg:px-12 lg:py-6 hover:bg-blue-700 transition font-medium"
        >
          {buttonLabel}
          <svg class="inline-flex ml-4 w-8 h-8 md:w-7 md:h-7 lg:w-10 lg:h-10 fill-white" viewBox="0 0 20 11">
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M0.628662 5.5C0.628662 5.16249 0.925718 4.88889 1.29215 4.88889H16.9411L12.7659 1.04323C12.5067 0.80458 12.5067 0.417645 12.7659 0.178991C13.0249 -0.0596635 13.4451 -0.0596635 13.7041 0.178991L19.0121 5.06788C19.2712 5.30653 19.2712 5.69347 19.0121 5.93212L13.7041 10.821C13.4451 11.0597 13.0249 11.0597 12.7659 10.821C12.5067 10.5824 12.5067 10.1954 12.7659 9.9568L16.9411 6.11111H1.29215C0.925718 6.11111 0.628662 5.83751 0.628662 5.5Z"
            ></path>
          </svg>
        </a>
      )}
    </div>
  </div>
</div>
