---
import Layout from "../layouts/Layout.astro"
import PageBanner from "../components/PageBanner.astro";
import bg from '../assets/contacto/contactobg.jpg';
import { contactInfo } from '../data/contacto.js';

const title = "Contacto - Industrias Polyvac";
const description = "Contáctanos por teléfono, email o WhatsApp. Visítanos en Cuautitlán Izcalli, Estado de México. Cotizaciones y soporte técnico para productos textiles.";
---

<Layout title={title} description={description}>
    <PageBanner imageUrl={bg} titulo="Contacto y nuestra Ubicación"/>
    
    <!-- Contenido principal -->
    <div class="font-fuenteprincipal">
        
        <!-- Mapa de ubicación -->
        <section class="py-16 bg-gray-200">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                
                <div class="bg-white  shadow-lg overflow-hidden">
                    <div class="grid lg:grid-cols-3">
                        <!-- Información de contacto adicional -->
                        <div class="bg-azulprimario text-white p-8 lg:p-12">
                            <h3 class="text-2xl font-bold mb-6">Información de Contacto</h3>
                            
                            <div class="space-y-6">
                                <!-- Dirección -->
                                <div class="flex items-start space-x-4">
                                    <svg class="w-6 h-6 text-white mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                                    </svg>
                                    <div>
                                        <h4 class="font-semibold mb-1">Dirección</h4>
                                        <p class="text-blue-100">{contactInfo.direccion.calle}</p>
                                        <p class="text-blue-100">{contactInfo.direccion.complejo}</p>
                                        <p class="text-blue-100">{contactInfo.direccion.ciudad}</p>
                                        <p class="text-blue-100">{contactInfo.direccion.codigoPostal}</p>
                                    </div>
                                </div>
                                
                                <!-- Teléfono -->
                                <div class="flex items-start space-x-4">
                                    <svg class="w-6 h-6 text-white mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                                    </svg>
                                    <div>
                                        <h4 class="font-semibold mb-1">Teléfonos</h4>
                                        {contactInfo.telefonos.map((telefono) => (
                                            <a href={telefono.href} class="text-blue-100 hover:text-white transition-colors block">
                                                {telefono.numero}
                                            </a>
                                        ))}
                                    </div>
                                </div>
                                
                                <!-- Email -->
                                <div class="flex items-start space-x-4">
                                    <svg class="w-6 h-6 text-white mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                                        <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
                                    </svg>
                                    <div>
                                        <h4 class="font-semibold mb-1">Email</h4>
                                        <a href={contactInfo.email.href} class="text-blue-100 hover:text-white transition-colors">
                                            {contactInfo.email.direccion}
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Mapa -->
                        <div class="lg:col-span-2 h-96 lg:h-auto min-h-[400px]">
                            <iframe 
                                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3757.3238617798693!2d-99.19039442475732!3d19.656183781671498!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85d1f587be9a2725%3A0xd7d4d961da5fcee6!2sINDUSTRIAS%20POLYVAC%20S.A.%20DE%20C.V.!5e0!3m2!1sen!2smx!4v1751316594642!5m2!1sen!2smx"
                                width="100%" 
                                height="100%" 
                                style="border:0;" 
                                allowfullscreen="" 
                                loading="lazy" 
                                referrerpolicy="no-referrer-when-downgrade"
                                class="w-full h-full"
                            ></iframe>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Enviar mensaje por WhatsApp -->
        <section class="py-16 bg-gray-200">
            <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="bg-white p-8 md:p-12 shadow-lg">
                    <div class="text-center mb-8">
                        <h2 class="text-4xl font-bold text-azulprimario mb-4">Escríbenos por WhatsApp</h2>
                        <p class="text-gray-600 text-lg">
                            Completa los campos y te redirigiremos a WhatsApp para iniciar la conversación.
                        </p>
                    </div>
                    
                    <form id="whatsappForm" class="space-y-6">
                        <div class="grid md:grid-cols-2 gap-6">
                            <div>
                                <label for="wa-name" class="block text-sm font-medium text-gray-700 mb-2">Nombre</label>
                                <input 
                                    type="text" 
                                    id="wa-name" 
                                    placeholder="Tu nombre"
                                    required
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition-colors"
                                >
                            </div>
                            <div>
                                <label for="wa-empresa" class="block text-sm font-medium text-gray-700 mb-2">Empresa (opcional)</label>
                                <input 
                                    type="text" 
                                    id="wa-empresa" 
                                    placeholder="Nombre de tu empresa"
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition-colors"
                                >
                            </div>
                        </div>
                        
                        <div>
                            <label for="wa-message" class="block text-sm font-medium text-gray-700 mb-2">Tu mensaje</label>
                            <textarea 
                                id="wa-message" 
                                rows="4"
                                placeholder="¿En qué podemos ayudarte?"
                                required
                                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition-colors resize-none"
                            ></textarea>
                        </div>
                        
                        <div class="text-center">
                            <button 
                                type="submit"
                                class="inline-flex items-center gap-3 bg-green-500 text-white px-8 py-3 font-medium hover:bg-green-600 transition-colors focus:ring-2 focus:ring-green-500 focus:ring-offset-2 outline-none rounded-lg text-lg"
                            >
                                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                                Enviar por WhatsApp
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </section>
        
    </div>
</Layout>

<script>
    document.getElementById('whatsappForm')?.addEventListener('submit', function(e) {
        e.preventDefault();
        const name = (document.getElementById('wa-name') as HTMLInputElement).value.trim();
        const empresa = (document.getElementById('wa-empresa') as HTMLInputElement).value.trim();
        const message = (document.getElementById('wa-message') as HTMLTextAreaElement).value.trim();
        
        let texto = `Hola, soy ${name}`;
        if (empresa) texto += ` de ${empresa}`;
        texto += `. ${message}`;
        
        const url = `https://wa.me/525559543369?text=${encodeURIComponent(texto)}`;
        window.open(url, '_blank');
    });
</script>
