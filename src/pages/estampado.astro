---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
import Badge from "../components/Badge.astro";
import products from "../data/estampado.js";

// Importar imágenes
import estampadoBanner from '../assets/hero/test.png';
import cubetaImage from '../assets/cubeta.png';

const title = "Línea de Estampado - Industrias Polyvac";
const description = "Catálogo de tintas plastisol, base agua, sublimación, fotoemulsiones y pigmentos de dispersión para estampación textil y serigrafía profesional.";

const subcategorias = [
    {
        titulo: "TINTAS TIPO PLASTISOL PARA SERIGRAFÍA",
        slug: "tintas-plastisol",
        descripcion: "Tintas versátiles de gran durabilidad y fácil manejo para impresión directa."
    },
    {
        titulo: "TINTAS TEXTILES BASE AGUA PARA SERIGRAFÍA",
        slug: "tintas-base-agua",
        descripcion: "Soluciones ecológicas con tacto suave y excelente transpirabilidad."
    },
    {
        titulo: "TINTAS PARA SUBLIMADO POR SERIGRAFÍA",
        slug: "tintas-sublimacion",
        descripcion: "Colores vibrantes para transferencia térmica sobre poliéster."
    },
    {
        titulo: "FOTOEMULSIONES PARA REVELADO DE PANTALLAS SERIGRÁFICAS",
        slug: "fotoemulsiones",
        descripcion: "Emulsiones de alta definición para todo tipo de tintas."
    },
    {
        titulo: "PIGMENTOS EN DISPERSIÓN BASE AGUA PARA PASTAS DE ESTAMPADO",
        slug: "pigmentos-dispersion",
        descripcion: "Coloración intensa y estable para bases acuosas."
    }
];
---

<Layout title={title} description={description}>
    <!-- Banner de página -->
    <PageBanner 
        imageUrl={estampadoBanner}
        titulo="Línea de Estampado"
    />

    <!-- Contenido principal -->
    <main class="font-fuenteprincipal">
        {subcategorias.map((subcategoria) => {
            const categoryProducts = products.filter(p => p.subcategoria === subcategoria.slug);
            
            // Agrupar productos por subtítulo (3er nivel) si existe
            const groups = [];
            let currentGroup = null;

            categoryProducts.forEach(product => {
                const groupTitle = product.subtitulo || "General";
                
                if (!currentGroup || currentGroup.title !== groupTitle) {
                    currentGroup = { 
                        title: groupTitle, 
                        products: [] 
                    };
                    groups.push(currentGroup);
                }
                currentGroup.products.push(product);
            });

            // Determinar si debemos mostrar los grupos visualmente
            // (Si hay más de un grupo, o si el único grupo tiene un título que no es "General")
            const showGroups = groups.length > 1 || (groups.length === 1 && groups[0].title !== "General");

            return (
                <section id={`categoria-${subcategoria.slug}`} class="py-20 scroll-mt-32">
                    <!-- Badge de subcategoría -->
                    <Badge text={subcategoria.titulo} />
                    

                    {/* Iterar sobre los grupos (o el único grupo "General") */}
                    {groups.map((group, groupIndex) => (
                        <div class="mx-auto max-w-7xl px-4 py-8">
                             {/* Mostrar título del grupo si es necesario (3er nivel) */}
                            {showGroups && (
                                <h3 class="text-2xl font-bold text-gray-800 mb-6 border-l-4 border-azulprimario pl-3">
                                    {group.title}
                                </h3>
                            )}

                            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                                        {group.products.map((producto) => (
                                            <div class="product-card flex flex-col p-3 rounded-lg shadow-md border border-gray-200 hover:shadow-lg transition-shadow bg-white">
                                                <a href={`/producto/${producto.id}`} class="block">
                                                    <div class="relative h-48 bg-gray-100 rounded mb-2 flex items-center justify-center overflow-hidden">
                                                        <Image 
                                                            src={producto.imagenes && producto.imagenes.length > 0 ? producto.imagenes[0] : cubetaImage} 
                                                            alt={producto.titulo}
                                                            class="w-full h-full object-cover"
                                                            width={533}
                                                            height={492}
                                                            loading="lazy"
                                                        />
                                                        {/* Polígono con el título */}
                                                        <div 
                                                            class="absolute bottom-0 left-0 px-4 py-2 z-10 flex items-center justify-center min-w-[120px]"
                                                            style={`background-color: ${producto.colorPrincipal || '#2563EB'}; opacity: 0.9; clip-path: polygon(0 0, calc(100% - 15px) 0, 100% 50%, calc(100% - 15px) 100%, 0 100%);`}
                                                        >
                                                            <div class="text-center">
                                                                <span class="text-white text-sm font-bold leading-tight">{producto.titulo}</span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </a>
                                                <div class="px-2 flex-1 flex flex-col">
                                                    {/* Opcional: Ocultar subtítulo si ya se usa como header de grupo, o dejarlo */}
                                                    {producto.subtitulo && !showGroups && (
                                                        <p class="text-xs text-gray-500 mb-1 font-semibold dark:text-gray-400">
                                                            {producto.subtitulo}
                                                        </p>
                                                    )}
                                                    {producto.descripcion && (
                                                        <div class="desc-wrapper relative">
                                                            <p class="desc-text text-sm text-gray-600 line-clamp-4 transition-all duration-200">
                                                                {producto.descripcion}
                                                            </p>
                                                            <button 
                                                                type="button"
                                                                class="desc-toggle text-xs text-azulprimario font-medium mt-1 hover:underline focus:outline-none hidden"
                                                                onclick="toggleDescription(event, this)"
                                                            >
                                                                Ver más ▼
                                                            </button>
                                                        </div>
                                                    )}
                                                    {!producto.descripcion && (
                                                        <div class="flex-1"></div>
                                                    )}
                                                </div>
                                                <a href={`/producto/${producto.id}`} class="mt-auto block w-full py-2.5 rounded text-center center text-sm font-medium transition-colors bg-azulprimario text-white hover:bg-blue-700 cursor-pointer">
                                                    Ver detalles
                                                </a>
                                            </div>
                                        ))}
                            </div>
                        </div>
                    ))}
                </section>
            );
        })}
    </main>

    <script is:inline>
        // Toggle descripción expandida
        function toggleDescription(event, btn) {
            event.preventDefault();
            event.stopPropagation();
            const wrapper = btn.closest('.desc-wrapper');
            const text = wrapper.querySelector('.desc-text');
            const isExpanded = text.classList.contains('desc-expanded');

            if (isExpanded) {
                text.classList.remove('desc-expanded');
                text.classList.add('line-clamp-3');
                btn.textContent = 'Ver más ▼';
            } else {
                text.classList.add('desc-expanded');
                text.classList.remove('line-clamp-3');
                btn.textContent = 'Ver menos ▲';
            }
        }

        // Detectar qué descripciones necesitan el botón "Ver más"
        function initDescriptionToggles() {
            document.querySelectorAll('.desc-wrapper').forEach(wrapper => {
                const text = wrapper.querySelector('.desc-text');
                const btn = wrapper.querySelector('.desc-toggle');
                if (!text || !btn) return;
                // Si el contenido está truncado, mostrar el botón
                if (text.scrollHeight > text.clientHeight + 2) {
                    btn.classList.remove('hidden');
                } else {
                    btn.classList.add('hidden');
                }
            });
        }

        document.addEventListener('DOMContentLoaded', initDescriptionToggles);
        window.addEventListener('resize', initDescriptionToggles);
    </script>

    <style>
        /* Estilos para las tarjetas del grid */
        .product-card {
            min-height: 380px;
            overflow: visible;
            position: relative;
        }

        /* Cuando la descripción se expande, permitir que la card crezca */
        .product-card:has(.desc-expanded) {
            z-index: 5;
        }

        .desc-text {
            transition: all 0.2s ease;
        }

        .desc-expanded {
            display: block !important;
            -webkit-line-clamp: unset !important;
        }

        /* Estilos para truncar texto */
        .line-clamp-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .line-clamp-3 {
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .line-clamp-6 {
            display: -webkit-box;
            -webkit-line-clamp: 6;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
    </style>
</Layout>
