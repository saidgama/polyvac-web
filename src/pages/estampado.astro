---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
import Badge from "../components/Badge.astro";
import productos from "../data/productos.js";

// Importar imágenes
import estampadoBanner from '../assets/hero/test.png';
import cubetaImage from '../assets/cubeta.png';

const title = "Línea de Estampado - Industrias Polyvac";
const description = "Tintas, pigmentos, colorantes, auxiliares y accesorios para estampación textil";

// Función para filtrar productos por taxonomía
function getProductosPorTaxonomia(taxonomiaId: number) {
    return productos.filter(producto => producto.taxonomias.includes(taxonomiaId));
}

// Datos hardcodeados para las subcategorías y taxonomías
const subcategorias = [
    {
        id: 1,
        nombre: "Por tipo de aplicación",
        descripcion: "Productos específicos según el tipo de tela y aplicación",
        taxonomias: [
            { id: 1, nombre: "Para algodón", slug: "para-algodon" },
            { id: 2, nombre: "Para poliéster", slug: "para-poliester" },
            { id: 3, nombre: "Para fondos claros", slug: "para-fondos-claros" },
            { id: 4, nombre: "Para fondos oscuros", slug: "para-fondos-oscuros" },
            { id: 5, nombre: "Efectos especiales", slug: "efectos-especiales" }
        ]
    },
    {
        id: 2,
        nombre: "Por tipo de formulación",
        descripcion: "Diferentes tipos de tintas según su composición",
        taxonomias: [
            { id: 7, nombre: "Tintas plastisol", slug: "tintas-plastisol" },
            { id: 8, nombre: "Tintas base agua", slug: "tintas-base-agua" },
            { id: 9, nombre: "Tintas de sublimación", slug: "tintas-sublimacion" },
            { id: 10, nombre: "Tintas DTF", slug: "tintas-dtf" }
        ]
    },
    {
        id: 3,
        nombre: "Materias primas y auxiliares",
        descripcion: "Componentes esenciales para la preparación de tintas",
        taxonomias: [
            { id: 11, nombre: "Pigmentos", slug: "pigmentos" },
            { id: 12, nombre: "Colorantes", slug: "colorantes" },
            { id: 13, nombre: "Auxiliares textiles", slug: "auxiliares-textiles" },
            { id: 14, nombre: "Acabados especiales", slug: "acabados-especiales" }
        ]
    },
    {
        id: 4,
        nombre: "Accesorios de serigrafía",
        descripcion: "Herramientas y accesorios para el proceso de estampación",
        taxonomias: [
            { id: 15, nombre: "Marcos", slug: "marcos" },
            { id: 16, nombre: "Mallas", slug: "mallas" },
            { id: 17, nombre: "Raseros", slug: "raseros" },
            { id: 18, nombre: "Emulsiones", slug: "emulsiones" }
        ]
    }
];
---

<Layout title={title} description={description}>
    <!-- Banner de página -->
    <PageBanner 
        imageUrl={estampadoBanner}
        titulo="Línea de Estampado"
    />

    <!-- Contenido principal -->
    <main class="font-fuenteprincipal">
        {subcategorias.map((subcategoria) => (
            <section class="py-12">
                <!-- Badge de subcategoría -->
                <Badge text={subcategoria.nombre} />
                
                <!-- Descripción de subcategoría -->
                <div class="mx-auto max-w-7xl px-4 py-4">
                    <p class="text-center text-lg md:text-xl text-azulsecundario max-w-4xl mx-auto">
                        {subcategoria.descripcion}
                    </p>
                </div>

                {/* Verificar si es la subcategoría de Accesorios de serigrafía */}
                {subcategoria.id === 4 ? (
                    <!-- Carrusel de productos directos para Accesorios -->
                    <div class="mx-auto max-w-7xl px-4 py-8">
                        <div class="relative">
                            <!-- Contenedor del carrusel -->
                            <div 
                                class="carousel-container overflow-hidden"
                                data-carousel="carousel-accesorios"
                            >
                                <div class="carousel-track flex transition-transform duration-300 ease-in-out">
                                    {/* Productos de accesorios de serigrafía - subcategoría 4 o placeholders */}
                                    {(() => {
                                        const productosAccesorios = productos.filter(producto => producto.subcategorias.includes(4));
                                        const productosAMostrar = productosAccesorios.length > 0 ? productosAccesorios : [
                                            {
                                                id: "placeholder-accesorios-1"  ,
                                                titulo: "Accesorio de ejemplo",
                                                descripcion: "Este es un accesorio de ejemplo para mostrar el diseño y estructura de la página.",
                                                imagenes: [cubetaImage],
                                                fichaTecnica: null,
                                                placeholder: true,
                                                colorPrincipal: "#95a5a6"
                                            },
                                            {
                                                id: "placeholder-accesorios-2",
                                                titulo: "Accesorio de ejemplo",
                                                descripcion: "Este es un accesorio de ejemplo para mostrar el diseño y estructura de la página.",
                                                imagenes: [cubetaImage],
                                                fichaTecnica: null,
                                                placeholder: true,
                                                colorPrincipal: "#7f8c8d"
                                            }
                                        ];
                                        
                                        return productosAMostrar.map((producto: any) => (
                                            <div class={`carousel-card p-4 rounded-lg shadow-md border border-gray-200 hover:shadow-lg transition-shadow ${producto.placeholder ? 'bg-gray-50' : 'bg-white'}`}>
                                                <div class="relative h-48 bg-gray-100 rounded mb-4 flex items-center justify-center overflow-hidden">
                                                    <Image 
                                                        src={cubetaImage} 
                                                        alt={producto.titulo}
                                                        class={`w-full h-full object-cover ${producto.placeholder ? 'opacity-50 grayscale' : ''}`}
                                                        width={533}
                                                        height={492}
                                                        loading="lazy"
                                                    />
                                                    {/* Polígo  no con el título del producto */}
                                                    {producto.colorPrincipal && (
                                                        <div 
                                                            class="absolute bottom-0 left-0 px-4 py-2 z-10 flex items-center justify-center min-w-[120px]"
                                                            style={`background-color: ${producto.colorPrincipal}; opacity: ${producto.placeholder ? '0.6' : '0.9'}; clip-path: polygon(0 0, calc(100% - 15px) 0, 100% 50%, calc(100% - 15px) 100%, 0 100%);`}
                                                        >
                                                            <div class="text-center">
                                                                <span class="text-white text-sm font-bold leading-tight">{producto.titulo}</span>
                                                            </div>
                                                        </div>
                                                    )}
                                                </div>
                                                <p class={`text-sm mb-4 line-clamp-3 ${producto.placeholder ? 'text-gray-400' : 'text-gray-600'}`}>
                                                    {producto.descripcion}
                                                </p>
                                                <div class="flex gap-2">
                                                    <a 
                                                        href={`/producto/${producto.id}`}
                                                        class={`flex-1 py-2 px-3 rounded text-sm transition text-center ${producto.placeholder ? 'bg-gray-300 text-gray-500 cursor-not-allowed' : 'bg-azulprimario text-white hover:bg-blue-700'}`}
                                                    >
                                                        {producto.placeholder ? 'Ejemplo' : 'Ver detalles'}
                                                    </a>
                                                    {producto.fichaTecnica && !producto.placeholder && (
                                                        <a 
                                                            href={producto.fichaTecnica} 
                                                            target="_blank"
                                                            class="bg-gray-200 text-gray-700 py-2 px-3 rounded text-sm hover:bg-gray-300 transition"
                                                            title="Ficha técnica"
                                                        >
                                                            📄
                                                        </a>
                                                    )}
                                                </div>
                                            </div>
                                        ));
                                    })()}
                                </div>
                            </div>

                            <!-- Botones de navegación del carrusel -->
                            <button 
                                class="carousel-prev absolute left-0 top-1/2 transform -translate-y-1/2 bg-azulprimario text-white p-2 rounded-full shadow-lg hover:bg-blue-700 transition"
                                onclick="moveCarousel('carousel-accesorios', -1)"
                            >
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                                </svg>
                            </button>
                            
                            <button 
                                class="carousel-next absolute right-0 top-1/2 transform -translate-y-1/2 bg-azulprimario text-white p-2 rounded-full shadow-lg hover:bg-blue-700 transition"
                                onclick="moveCarousel('carousel-accesorios', 1)"
                            >
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                </svg>
                            </button>
                        </div>
                    </div>
                ) : (
                    <!-- Taxonomías normales para las otras subcategorías -->
                    {subcategoria.taxonomias.map((taxonomia) => (
                        <div class="mx-auto max-w-7xl px-4 py-8">
                            <!-- Título de taxonomía -->
                            <div class="mb-6">
                                <h3 class="text-2xl md:text-3xl font-bold text-azulsecundario mb-2">
                                    {taxonomia.nombre}
                                </h3>
                                <div class="w-20 h-1 bg-azulprimario"></div>
                            </div>

                            <!-- Carrusel de productos -->
                            <div class="relative">
                                <!-- Contenedor del carrusel -->
                                <div 
                                    class="carousel-container overflow-hidden"
                                    data-carousel={`carousel-${taxonomia.id}`}
                                >
                                    <div class="carousel-track flex transition-transform duration-300 ease-in-out">
                                        {/* Productos reales o placeholders */}
                                        {(() => {
                                            const productosEnTaxonomia = getProductosPorTaxonomia(taxonomia.id);
                                            const productosAMostrar = productosEnTaxonomia.length > 0 ? productosEnTaxonomia : [
                                                {
                                                    id: `placeholder-${taxonomia.id}-1`,
                                                    titulo: "Producto de ejemplo",
                                                    descripcion: "Este es un producto de ejemplo para mostrar el diseño y estructura de la página.",
                                                    imagenes: [cubetaImage],
                                                    fichaTecnica: null,
                                                    placeholder: true,
                                                    colorPrincipal: "#bdc3c7"
                                                },
                                                {
                                                    id: `placeholder-${taxonomia.id}-2`,
                                                    titulo: "Producto de ejemplo",
                                                    descripcion: "Este es un producto de ejemplo para mostrar el diseño y estructura de la página.",
                                                    imagenes: [cubetaImage],
                                                    fichaTecnica: null,
                                                    placeholder: true,
                                                    colorPrincipal: "#95a5a6"
                                                }
                                            ];
                                            
                                            return productosAMostrar.map((producto: any) => (
                                                <div class={`carousel-card p-4 rounded-lg shadow-md border border-gray-200 hover:shadow-lg transition-shadow ${producto.placeholder ? 'bg-gray-50' : 'bg-white'}`}>
                                                    <div class="relative h-48 bg-gray-100 rounded mb-4 flex items-center justify-center overflow-hidden">
                                                        <Image 
                                                            src={cubetaImage} 
                                                            alt={producto.titulo}
                                                            class={`w-full h-full object-cover ${producto.placeholder ? 'opacity-50 grayscale' : ''}`}
                                                            width={533}
                                                            height={492}
                                                            loading="lazy"
                                                        />
                                                        {/* Polígono con el título del producto */}
                                                        {producto.colorPrincipal && (
                                                            <div 
                                                                class="absolute bottom-0 left-0 px-4 py-2 z-10 flex items-center justify-center min-w-[120px]"
                                                                style={`background-color: ${producto.colorPrincipal}; opacity: ${producto.placeholder ? '0.6' : '0.9'}; clip-path: polygon(0 0, calc(100% - 15px) 0, 100% 50%, calc(100% - 15px) 100%, 0 100%);`}
                                                            >
                                                                <div class="text-center">
                                                                    <span class="text-white text-sm font-bold leading-tight">{producto.titulo}</span>
                                                                </div>
                                                            </div>
                                                        )}
                                                    </div>
                                                    <p class={`text-sm mb-4 line-clamp-3 ${producto.placeholder ? 'text-gray-400' : 'text-gray-600'}`}>
                                                        {producto.descripcion}
                                                    </p>
                                                    <div class="flex gap-2">
                                                        <a 
                                                            href={`/producto/${producto.id}`}
                                                            class={`flex-1 py-2 px-3 rounded text-sm transition text-center ${producto.placeholder ? 'bg-gray-300 text-gray-500 cursor-not-allowed' : 'bg-azulprimario text-white hover:bg-blue-700'}`}
                                                        >
                                                            {producto.placeholder ? 'Ejemplo' : 'Ver detalles'}
                                                        </a>
                                                        {producto.fichaTecnica && !producto.placeholder && (
                                                            <a 
                                                                href={producto.fichaTecnica} 
                                                                target="_blank"
                                                                class="bg-gray-200 text-gray-700 py-2 px-3 rounded text-sm hover:bg-gray-300 transition"
                                                                title="Ficha técnica"
                                                            >
                                                                📄
                                                            </a>
                                                        )}
                                                    </div>
                                                </div>
                                            ));
                                        })()}
                                    </div>
                                </div>

                                <!-- Botones de navegación del carrusel -->
                                <button 
                                    class="carousel-prev absolute left-0 top-1/2 transform -translate-y-1/2 bg-azulprimario text-white p-2 rounded-full shadow-lg hover:bg-blue-700 transition"
                                    onclick={`moveCarousel('carousel-${taxonomia.id}', -1)`}
                                >
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                                    </svg>
                                </button>
                                
                                <button 
                                    class="carousel-next absolute right-0 top-1/2 transform -translate-y-1/2 bg-azulprimario text-white p-2 rounded-full shadow-lg hover:bg-blue-700 transition"
                                    onclick={`moveCarousel('carousel-${taxonomia.id}', 1)`}
                                >
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    ))}
                )}
            </section>
        ))}
    </main>

    <!-- JavaScript para el carrusel -->
    <script is:inline>
        function moveCarousel(carouselId, direction) {
            const container = document.querySelector(`[data-carousel="${carouselId}"]`);
            if (!container) return;
            
            const track = container.querySelector('.carousel-track');
            if (!track) return;
            
            const cardWidth = 280; // Ancho de la tarjeta + margen
            const totalCards = track.children.length;
            
            // Obtener posición actual
            const currentTransform = track.style.transform || 'translateX(0px)';
            const currentTranslate = parseInt(currentTransform.replace('translateX(', '').replace('px)', '')) || 0;
            
            // Calcular nueva posición
            let newTranslate = currentTranslate + (direction * cardWidth * -1);
            
            // Establecer límites
            const maxTranslate = 0;
            const minTranslate = -(totalCards - 1) * cardWidth;
            
            // Aplicar límites
            if (newTranslate > maxTranslate) {
                newTranslate = maxTranslate;
            } else if (newTranslate < minTranslate) {
                newTranslate = minTranslate;
            }
            
            // Aplicar transformación
            track.style.transform = `translateX(${newTranslate}px)`;
            
            // Actualizar botones
            updateCarouselButtons(carouselId, newTranslate, maxTranslate, minTranslate);
        }

        function updateCarouselButtons(carouselId, currentTranslate, maxTranslate, minTranslate) {
            const container = document.querySelector(`[data-carousel="${carouselId}"]`);
            if (!container) return;
            
            const prevButton = container.parentElement.querySelector('.carousel-prev');
            const nextButton = container.parentElement.querySelector('.carousel-next');
            
            if (prevButton) {
                if (currentTranslate >= maxTranslate) {
                    prevButton.style.opacity = '0.5';
                    prevButton.style.cursor = 'not-allowed';
                } else {
                    prevButton.style.opacity = '1';
                    prevButton.style.cursor = 'pointer';
                }
            }
            
            if (nextButton) {
                if (currentTranslate <= minTranslate) {
                    nextButton.style.opacity = '0.5';
                    nextButton.style.cursor = 'not-allowed';
                } else {
                    nextButton.style.opacity = '1';
                    nextButton.style.cursor = 'pointer';
                }
            }
        }

        // Inicializar carruseles cuando la página carga
        function initializeCarousels() {
            const carousels = document.querySelectorAll('.carousel-container');
            carousels.forEach(carousel => {
                const carouselId = carousel.getAttribute('data-carousel');
                if (carouselId) {
                    updateCarouselButtons(carouselId, 0, 0, 0);
                }
            });
        }

        // Reiniciar carruseles en cambio de tamaño
        function resetCarousels() {
            const carousels = document.querySelectorAll('.carousel-container');
            carousels.forEach(carousel => {
                const track = carousel.querySelector('.carousel-track');
                if (track) {
                    track.style.transform = 'translateX(0px)';
                }
                const carouselId = carousel.getAttribute('data-carousel');
                if (carouselId) {
                    updateCarouselButtons(carouselId, 0, 0, 0);
                }
            });
        }

        // Event listeners
        document.addEventListener('DOMContentLoaded', initializeCarousels);
        window.addEventListener('resize', resetCarousels);
    </script>

    <!-- Estilos adicionales -->
    <style>
        .carousel-container {
            margin: 0 3rem; /* Espacio para los botones de navegación */
        }
        
        @media (max-width: 768px) {
            .carousel-container {
                margin: 0 2rem;
            }
        }

        /* Estilos para las tarjetas del carrusel */
        .carousel-card {
            width: 256px !important; /* Ancho fijo */
            margin-right: 24px !important; /* Espacio entre tarjetas */
            flex-shrink: 0; /* No permitir que se reduzcan */
        }

        /* Asegurar que el flex funcione correctamente */
        .carousel-track {
            display: flex !important;
            transition: transform 0.3s ease-in-out !important;
        }

        /* Estilos para los botones del carrusel */
        .carousel-prev,
        .carousel-next {
            transition: opacity 0.3s ease, background-color 0.3s ease;
            z-index: 10; /* Reducido para estar por debajo del header */
        }

        /* Estilos para truncar texto */
        .line-clamp-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .line-clamp-3 {
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
    </style>
</Layout>
