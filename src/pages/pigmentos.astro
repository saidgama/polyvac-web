---
import Layout from "../layouts/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
import Badge from "../components/Badge.astro";
import pigmentos from "../data/pigmentos.js";

// Importar imágenes
import bannerImage from '../assets/hero/test.png';

const title = "Pigmentos - Industrias Polyvac";

const inorganicos = pigmentos
    .filter(p => p.subcategoria === "inorganico")
    .sort((a, b) => a.titulo.localeCompare(b.titulo));

const organicos = pigmentos
    .filter(p => p.subcategoria === "organico")
    .sort((a, b) => a.titulo.localeCompare(b.titulo));
---

<Layout title={title} description="Pigmentos orgánicos e inorgánicos de alta calidad para aplicaciones industriales textiles. Variedad de colores y presentaciones disponibles.">
    <PageBanner 
        imageUrl={bannerImage}
        titulo="Pigmentos"
    />
    
    <div class="container mx-auto px-4 py-16 min-h-[50vh]">

        <!-- Subcategoría: Inorgánicos -->
        <section id="inorganicos" class="mb-20">
            <div class="relative mb-10">
                <div class="badge-tight">
                    <Badge text="Pigmentos Inorgánicos" />
                </div>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-5">
                {inorganicos.map((product) => (
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-all duration-300 group flex flex-col">
                        {/* Swatch de color */}
                        <div class="relative aspect-square flex items-center justify-center overflow-hidden"
                             style={`background-color: ${product.hexColor || '#E5E7EB'};`}>
                            {!product.hexColor && (
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V8a4 4 0 014-4h10a4 4 0 014 4v1M8 4v16m0-8h12m-4-4l4 4-4 4"></path>
                                    </svg>
                                </div>
                            )}
                        </div>
                        {/* Info */}
                        <div class="p-3 flex-1 flex flex-col justify-between">
                            <h3 class="text-xs font-bold text-gray-800 leading-tight mb-1">{product.titulo}</h3>
                            <span class="text-[11px] text-gray-500 font-mono">{product.colorIndex}</span>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- Subcategoría: Orgánicos -->
        <section id="organicos" class="mb-16">
            <div class="relative mb-10">
                <div class="badge-tight">
                    <Badge text="Pigmentos Orgánicos" />
                </div>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-5">
                {organicos.map((product) => (
                    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-all duration-300 group flex flex-col">
                        {/* Swatch de color */}
                        <div class="relative aspect-square flex items-center justify-center overflow-hidden"
                             style={`background-color: ${product.hexColor || '#E5E7EB'};`}>
                            {!product.hexColor && (
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <svg class="w-10 h-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V8a4 4 0 014-4h10a4 4 0 014 4v1M8 4v16m0-8h12m-4-4l4 4-4 4"></path>
                                    </svg>
                                </div>
                            )}
                        </div>
                        {/* Info */}
                        <div class="p-3 flex-1 flex flex-col justify-between">
                            <h3 class="text-xs font-bold text-gray-800 leading-tight mb-1">{product.titulo}</h3>
                            <span class="text-[11px] text-gray-500 font-mono">{product.colorIndex}</span>
                        </div>
                    </div>
                ))}
            </div>
        </section>

    </div>
</Layout>

<style>
    .badge-tight :global(div) {
        margin: 0;
    }
</style>
