---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
const title = "Industrias Polyvac";
const description = "Inicio de la pagina.";

import CategoryCard from "../components/CategoryCard.astro";

import bgHero from "../assets/hero/color-explosion.jpg";
import Badge from "../components/Badge.astro";
import oekotexLogo from '../assets/acercade/oekotex.png';
import bluesignLogo from '../assets/acercade/bluesign.png';  
import bureauVeritasLogo from '../assets/acercade/bureau.png';
import productBanner from '../assets/index/productbanner.png';
import productSplashBg from '../assets/hero/test.png';
import contactoBg from '../assets/contacto/contactobg.jpg';
import maquina from '../assets/index/maquina.jpeg';
import textil from '../assets/index/textil.jpeg';
import colores from '../assets/index/colores.jpeg';
import catalogo from '../assets/index/catalogo.png';  
import color from '../assets/index/color.jpeg'; 
import maquinaria from '../assets/index/maquinaria.jpeg';

// Importar productos locales
import productosData from '../data/productos.js';
import productosEstampado from '../data/estampado.js';
import productosColorantes from '../data/colorantes.js';
import productosEfectos from '../data/efectos-especiales.js';
import productosAccesorios from '../data/accesorios-consumibles.js';

const productos = [...productosData, ...productosEstampado, ...productosColorantes, ...productosEfectos, ...productosAccesorios];

// Obtener los primeros 4 productos como destacados
const productosDestacados = productos.slice(0, 4);

// Imagen para la categoría de estampado
import estampadoImage from '../assets/card1.png';
import colorantesImage from '../assets/cardColorantes.png';
import efectosespeciales from '../assets/cardEspeciales.png';
import tintoreriaImage from '../assets/cardTintoreria.png';
import masterbatchImage from '../assets/cardMasterBatch.jpeg';
import consumiblesImage from '../assets/cardConsumibles.png';
import digitalImage from '../assets/cardDigital.png';
import pigmentosImage from '../assets/cardPigmentos.jpg';

// Imagen de cubeta para productos
import cubetaImage from '../assets/cubeta.png';

const industriasCards = [
    {
        id: "01.",
        title: "Textil",
        subtitle: "Procesos continuos de teñido",
        overlayTitle: "Laboratorios textiles",
        description: "Pigmentos de alta solidez y auxiliares que mantienen la precisión del color en cada lote productivo.",
        ctaLabel: "Ver línea textil",
        href: "/estampado",
        background: textil
    },
    {
        id: "02.",
        title: "Maquinaria",
        subtitle: "La mejor maquinaria",
        overlayTitle: "Nuestra maquinaria",
        description: "Contamos con la mejor maquinaria para la fabricación de productos químicos industriales.",
        ctaLabel: "Ver más",
        href: "/acerca",
        background: maquina
    },
    {
        id: "03.",
        title: "Colores",
        subtitle: "La mejor gama de colores",
        overlayTitle: "Pigmentos y colorantes",
        description: "Contamos con una amplia variedad de pigmentos y colorantes para satisfacer todas sus necesidades industriales.",
        ctaLabel: "Ver catálogo",
        href: "/estampado",
        background: colores
    },
    {
        id: "04.",
        title: "Nuestra fabrica",
        subtitle: "Contamos con una fabrica industrial",
        overlayTitle: "Plantas industriales",
        description: "Tenemos una fabrica para atender sus necesidades industriales.",
        ctaLabel: "Contáctanos",
        href: "/contacto",
        background: contactoBg
    }
];

const industryCarouselSlides = [
    {
        id: "01",
        title: "Industria del color",
        description: "Las mejores soluciones químicas para la industria del color, desde pigmentos hasta resinas especializadas.",
        href: "/contacto",
        ctaLabel: "Ver más",
        image: color
    },
    {
        id: "02",
        eyebrow: "Infraestructura",
        title: "Nuestra infraestructura",
        description: "Contamos con multiples instalaciones y la mejor maquinaria para garantizar la calidad en cada etapa de producción.",
        href: "/busqueda",
        ctaLabel: "Ver más",
        image: maquinaria
    },
    {
        id: "03",
        title: "Amplio catalogo",
        description: "Tenemos un amplio catalogo de productos quimicos industriales para diversas aplicaciones.",
        href: "/cotizador",
        ctaLabel: "Ver más",
        image: catalogo
    }
];
---

<Layout title={title} description={description}>
    <section class="hero-section" id="home">
        <div class="hero-background"></div>
        <canvas id="lava-lamp-canvas"></canvas>
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="badge">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M10 3.5a1.5 1.5 0 011.06.44l5.25 5.25a1.5 1.5 0 010 2.12l-5.25 5.25a1.5 1.5 0 01-2.12 0L3.94 11.31a1.5 1.5 0 010-2.12l5.25-5.25A1.5 1.5 0 0110 3.5zm0 2.12L6.12 9.5h7.76L10 5.62z" />
                </svg>
                <span>Soluciones Químicas Profesionales</span>
            </div>
            <h1>Expertos en Color: <br> <span class="text-yellow-400">Químicos para la Industria</span></h1>
            <p>Fabricamos y distribuimos una amplia gama de productos químicos, resinas, pigmentos y colorantes, ofreciendo soluciones integrales para la industria del color.</p>
            <div class="hero-video-container" id="hero-video-wrap">
                <video 
                    id="hero-video"
                    class="hero-video"
                    muted
                    playsinline
                    preload="auto"
                >
                    <source src="/videos/video-hero.mp4" type="video/mp4" />
                </video>
                <!-- Controles personalizados -->
                <div class="hero-video-controls" id="hero-video-controls">
                    <button id="vid-rewind" class="vid-btn" title="Retroceder 10s">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12.066 11.2a1 1 0 000 1.6l5.334 4A1 1 0 0019 16V8a1 1 0 00-1.6-.8l-5.334 4zM4.066 11.2a1 1 0 000 1.6l5.334 4A1 1 0 0011 16V8a1 1 0 00-1.6-.8l-5.334 4z"></path></svg>
                    </button>
                    <button id="vid-playpause" class="vid-btn" title="Pausar / Reproducir">
                        <svg id="vid-icon-play" class="w-6 h-6 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"></path></svg>
                        <svg id="vid-icon-pause" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"></path></svg>
                    </button>
                    <div class="vid-progress-wrap" id="vid-progress-wrap">
                        <div class="vid-progress-bar" id="vid-progress-bar"></div>
                    </div>
                    <span class="vid-time" id="vid-time">0:00</span>
                </div>
            </div>
            <div class="hero-stats">
                <div>
                    <span class="stat-number">+500</span>
                    <span class="stat-label">Productos</span>
                </div>
                <div>
                    <span class="stat-number">+25</span>
                    <span class="stat-label">Años de Experiencia</span>
                </div>
            </div>
        </div>
    </section>
    <section>
        <!-- Sección de cards de categorias -->
    <Badge text="Nuestras Líneas de Productos"/>

    <!-- Estampado -->
    <CategoryCard
        imageUrl={estampadoImage}
        altText="Línea de productos para estampación textil"
        title="Línea de Estampado"
        description="Tintas, pigmentos, colorantes, auxiliares y accesorios para estampado."
        buttonLabel="Ver Catalogo"
        buttonHref="/estampado"
        position="right"
    />

    <!-- Tintorería -->
    <CategoryCard
        imageUrl={tintoreriaImage}
        altText="Productos para tintorería industrial"
        title="Tintorería"
        description="Productos químicos especializados para procesos de teñido industrial y textil."
        buttonLabel="Ver Productos"
        buttonHref="/tintoreria"
        position="left"
    />

    <!-- Colorantes -->
    <CategoryCard
        imageUrl={colorantesImage}
        altText="Colorantes industriales"
        title="Colorantes"
        description="Amplia gama de colorantes para diversas aplicaciones industriales y textiles."
        buttonLabel="Ver Productos"
        buttonHref="/colorantes"
        position="right"
    />

    <!-- Efectos Especiales -->
    <CategoryCard
        imageUrl={efectosespeciales}
        altText="Efectos especiales para textiles"
        title="Efectos Especiales"
        description="Productos innovadores para crear efectos únicos en textiles."
        buttonLabel="Ver Productos"
        buttonHref="/efectos-especiales"
        position="left"
    />

    <!-- Zona Digital -->
    <CategoryCard
        imageUrl={digitalImage}
        altText="Tintas para impresión digital"
        title="Zona Digital"
        description="Tintas de alta calidad para impresión digital textil y sublimación."
        buttonLabel="Ver Productos"
        buttonHref="/zona-digital"
        position="right"
    />

    <!-- Pigmentos -->
    <CategoryCard
        imageUrl={pigmentosImage}
        altText="Pigmentos industriales"
        title="Pigmentos"
        description="Pigmentos de alta solidez y calidad para múltiples aplicaciones industriales."
        buttonLabel="Ver Productos"
        buttonHref="/pigmentos"
        position="left"
    />

    <!-- Masterbatch -->
    <CategoryCard
        imageUrl={masterbatchImage}
        altText="Masterbatch para plásticos"
        title="Masterbatch"
        description="Concentrados de color y aditivos para la industria del plástico."
        buttonLabel="Ver Productos"
        buttonHref="/masterbatch"
        position="right"
    />

    <!-- Accesorios y Consumibles -->
    <CategoryCard
        imageUrl={consumiblesImage}
        altText="Accesorios y consumibles"
        title="Accesorios y Consumibles"
        description="Herramientas, materiales y consumibles complementarios para la industria."
        buttonLabel="Ver Productos"
        buttonHref="/accesorios-consumibles"
        position="left"
    />

    </section>

    <!-- Banner intermedio bajo la línea de productos -->
    <section id="product-splash-banner" class="relative overflow-hidden">
        <!-- Fondo con imagen -->
        <div
            class="product-splash-bg absolute inset-0 -z-10"
            style={`background-image: url(${productSplashBg.src});`}
        ></div>
        <div class="relative mx-auto max-w-7xl px-0 sm:px-6 lg:px-8">
            <div class="relative h-64 sm:h-72 md:h-80 lg:h-96 xl:h-[28rem]">
                <div id="banner-content" class="absolute inset-0 w-full h-full">
                    <Image
                        src={productBanner}
                        alt="Banner Polyvac"
                        class="w-full h-full object-cover object-center select-none"
                        draggable="false"
                    />
                </div>
            </div>
        </div>
    </section>

    <section class="experience-carousel">
        <div class="carousel-wrapper">
            <div class="carousel-track" data-carousel>
                {industryCarouselSlides.map((slide, index) => (
                    <article class={`carousel-slide${index === 0 ? ' is-active' : ''}`} data-slide-index={index}>
                        <div class="carousel-media">
                            <Image
                                src={slide.image}
                                alt={slide.title}
                                class="carousel-image"
                                loading="lazy"
                            />
                        </div>
                        <div class="carousel-gradient"></div>
                        <div class="carousel-content">
                            <span class="carousel-eyebrow">{slide.eyebrow}</span>
                            <div class="carousel-title-row">
                                <span class="carousel-index">{slide.id}.</span>
                                <h3>{slide.title}</h3>
                            </div>
                            <p>{slide.description}</p>
                            <a class="carousel-cta" href={slide.href}>{slide.ctaLabel}</a>
                        </div>
                    </article>
                ))}
            </div>
            <div class="carousel-dots" aria-live="polite">
                {industryCarouselSlides.map((slide, index) => (
                    <button
                        type="button"
                        class={`carousel-dot${index === 0 ? ' is-active' : ''}`}
                        data-carousel-dot={index}
                        aria-label={`Mostrar ${slide.title}`}
                    ></button>
                ))}
            </div>
        </div>
    </section>

    <section class="industry-showcase">
        <div class="mx-auto max-w-7xl px-4">
            <Badge text="Una empresa de calidad" />
        </div>
        <div class="industry-grid-wrap">
            <div class="industry-grid industry-grid--flush">
                {industriasCards.map((card) => (
                    <article
                        class="industry-card"
                        style={`background-image: linear-gradient(140deg, rgba(5, 8, 20, 0.85), rgba(5, 8, 20, 0.4)), url(${card.background ? card.background.src : bgHero.src});`}
                        tabindex="0"
                    >
                        <div class="industry-card__static">
                            <span class="industry-card__number">{card.id}</span>
                            <p class="industry-card__title">{card.title}</p>
                            <p class="industry-card__subtitle">{card.subtitle}</p>
                        </div>
                        <div class="industry-card__overlay">
                            <p class="industry-card__overlay-label">{card.overlayTitle}</p>
                            <p class="industry-card__overlay-text">{card.description}</p>
                            <a class="industry-card__cta" href={card.href}>{card.ctaLabel}</a>
                        </div>
                    </article>
                ))}
            </div>
        </div>
    </section>
    
    <Badge text="Productos destacados" />

    <!-- Sección de productos destacados -->
    <div class="mx-auto max-w-7xl px-4 py-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {productosDestacados.map(producto => (
                <div class="bg-white rounded-lg shadow-2xl overflow-hidden max-w-sm mx-auto font-fuenteprincipal">
                    <!-- Imagen del producto -->
                    <div class="relative h-64">
                        <Image 
                            src={producto.imagenes?.[0] ?? cubetaImage} 
                            alt={`Imagen de ${producto.titulo}`}
                            class="w-full h-64 object-cover"
                        />
                        <div 
                            class="absolute bottom-0 left-0 px-6 py-4 z-10 flex items-center justify-center min-w-[140px]"
                            style={`background-color: ${producto.colorPrincipal}; opacity: 0.9; clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 50%, calc(100% - 20px) 100%, 0 100%);`}
                        >
                            <div class="text-center">
                                <span class="text-white text-sm font-light block">Linea</span>
                                <span class="text-white text-lg font-bold leading-tight">{producto.titulo}</span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Contenido -->
                    <div class="p-4">
                        <a
                            href={`/producto/${producto.id}`}
                            class="inline-flex items-center justify-center bg-azulprimario text-white text-base font-medium px-6 py-3 w-full hover:bg-blue-700 transition-colors"
                        >
                            Ver Producto
                        </a>
                    </div>
                </div>
            ))}
        </div>
    </div>

    <!-- Certificaciones -->
    <section class="py-16 mt-15 overflow-hidden">
        <div class="mb-12 px-4">
            <h2 class="text-4xl md:text-5xl font-bold text-center mb-4 bg-gradient-to-r from-green-500 via-blue-500 to-red-500 bg-clip-text text-transparent">
                CERTIFICACIONES Y NORMAS
            </h2>
            <p class="text-center text-lg md:text-xl font-medium max-w-3xl mx-auto bg-gradient-to-r from-gray-600 to-gray-800 bg-clip-text text-transparent">
                Todos nuestros productos cumplen con las normas requeridas por:
            </p>
        </div>
        
        <div class="grid md:grid-cols-3 gap-0">
            <!-- OEKOTEX 2024 - Verde -->
            <div class="relative py-16 px-8 text-center min-h-[450px] flex flex-col justify-center items-center transition-all duration-300 hover:scale-105">
                <!-- Fondo con gradiente verde -->
                <div class="absolute inset-0 bg-gradient-to-br from-green-400 via-green-500 to-emerald-600 opacity-85"></div>
                
                <!-- Contenido -->
                <div class="relative z-10">
                    <div class="w-40 h-40 bg-white rounded-2xl flex items-center justify-center mx-auto mb-6 p-6 shadow-2xl transform transition-transform hover:rotate-3">
                        <Image 
                            src={oekotexLogo} 
                            alt="Logo OEKOTEX 2024" 
                            class="w-full h-full object-contain"
                        />
                    </div>
                    <h3 class="text-3xl font-bold text-white mb-2 drop-shadow-lg">OEKOTEX</h3>
                    <h4 class="text-2xl font-bold text-green-100 mb-4">2024</h4>
                    <p class="text-base text-white max-w-xs mx-auto drop-shadow-md">
                        Estándar internacional para textiles libres de sustancias nocivas
                    </p>
                </div>
            </div>

            <!-- BLUESIGN - Azul -->
            <div class="relative py-16 px-8 text-center min-h-[450px] flex flex-col justify-center items-center transition-all duration-300 hover:scale-105">
                <!-- Fondo con gradiente azul -->
                <div class="absolute inset-0 bg-gradient-to-br from-blue-400 via-blue-600 to-indigo-700 opacity-85"></div>
                
                <!-- Contenido -->
                <div class="relative z-10">
                    <div class="w-40 h-40 bg-white rounded-2xl flex items-center justify-center mx-auto mb-6 p-6 shadow-2xl transform transition-transform hover:rotate-3">
                        <Image 
                            src={bluesignLogo} 
                            alt="Logo Bluesign" 
                            class="w-full h-full object-contain"
                        />
                    </div>
                    <h3 class="text-3xl font-bold text-white mb-2 drop-shadow-lg">BLUESIGN</h3>
                    <h4 class="text-2xl font-bold text-blue-100 mb-4">APPROVED</h4>
                    <p class="text-base text-white max-w-xs mx-auto drop-shadow-md">
                        Sistema de gestión para una producción textil sostenible
                    </p>
                </div>
            </div>

            <!-- BUREAU VERITAS - Rojo -->
            <div class="relative py-16 px-8 text-center min-h-[450px] flex flex-col justify-center items-center transition-all duration-300 hover:scale-105">
                <!-- Fondo con gradiente rojo -->
                <div class="absolute inset-0 bg-gradient-to-br from-red-400 via-red-600 to-rose-700 opacity-85"></div>
                
                <!-- Contenido -->
                <div class="relative z-10">
                    <div class="w-40 h-40 bg-white rounded-2xl flex items-center justify-center mx-auto mb-6 p-6 shadow-2xl transform transition-transform hover:rotate-3">
                        <Image 
                            src={bureauVeritasLogo} 
                            alt="Logo Bureau Veritas" 
                            class="w-full h-full object-contain"
                        />
                    </div>
                    <h3 class="text-3xl font-bold text-white mb-2 drop-shadow-lg">BUREAU</h3>
                    <h4 class="text-3xl font-bold text-red-100 mb-4">VERITAS</h4>
                    <p class="text-base text-white max-w-xs mx-auto drop-shadow-md">
                        Líder mundial en servicios de inspección, certificación y ensayos
                    </p>
                </div>
            </div>
        </div>
    </section>
    <script is:inline src="/js/lava-lamp.js"></script>
    <script>
        if (typeof window !== 'undefined') {
            window.addEventListener('load', function() {
                const video = document.getElementById('hero-video') as HTMLVideoElement | null;
                if (!video) return;

                let volumeInterval: ReturnType<typeof setInterval> | null = null;

                function fadeInVolume(vid: HTMLVideoElement) {
                    // Unmute and start at very low volume
                    vid.muted = false;
                    vid.volume = 0.05;

                    if (volumeInterval) clearInterval(volumeInterval);

                    volumeInterval = setInterval(() => {
                        if (vid.volume < 0.95) {
                            vid.volume = Math.min(vid.volume + 0.05, 1);
                        } else {
                            vid.volume = 1;
                            if (volumeInterval) clearInterval(volumeInterval);
                            volumeInterval = null;
                        }
                    }, 200); // ~4 seconds to reach full volume
                }

                function fadeOutVolume(vid: HTMLVideoElement) {
                    if (volumeInterval) clearInterval(volumeInterval);

                    volumeInterval = setInterval(() => {
                        if (vid.volume > 0.05) {
                            vid.volume = Math.max(vid.volume - 0.1, 0);
                        } else {
                            vid.volume = 0;
                            vid.muted = true;
                            vid.pause();
                            if (volumeInterval) clearInterval(volumeInterval);
                            volumeInterval = null;
                        }
                    }, 100);
                }

                let userPaused = false;

                // Controls
                const playPauseBtn = document.getElementById('vid-playpause');
                const rewindBtn = document.getElementById('vid-rewind');
                const iconPlay = document.getElementById('vid-icon-play');
                const iconPause = document.getElementById('vid-icon-pause');
                const progressWrap = document.getElementById('vid-progress-wrap');
                const progressBar = document.getElementById('vid-progress-bar');
                const timeLabel = document.getElementById('vid-time');

                function updateIcons() {
                    if (video.paused) {
                        iconPlay?.classList.remove('hidden');
                        iconPause?.classList.add('hidden');
                    } else {
                        iconPlay?.classList.add('hidden');
                        iconPause?.classList.remove('hidden');
                    }
                }

                function formatTime(s: number) {
                    const m = Math.floor(s / 60);
                    const sec = Math.floor(s % 60);
                    return m + ':' + (sec < 10 ? '0' : '') + sec;
                }

                // Play / Pause
                playPauseBtn?.addEventListener('click', () => {
                    if (video.paused) {
                        userPaused = false;
                        video.play().then(() => fadeInVolume(video)).catch(() => {});
                    } else {
                        userPaused = true;
                        video.pause();
                    }
                    updateIcons();
                });

                // Rewind 10s
                rewindBtn?.addEventListener('click', () => {
                    video.currentTime = Math.max(video.currentTime - 10, 0);
                });

                // Progress bar click to seek
                progressWrap?.addEventListener('click', (e: MouseEvent) => {
                    const rect = progressWrap.getBoundingClientRect();
                    const pct = (e.clientX - rect.left) / rect.width;
                    video.currentTime = pct * video.duration;
                });

                // Update progress bar & time
                video.addEventListener('timeupdate', () => {
                    if (video.duration) {
                        const pct = (video.currentTime / video.duration) * 100;
                        if (progressBar) progressBar.style.width = pct + '%';
                        if (timeLabel) timeLabel.textContent = formatTime(video.currentTime);
                    }
                });

                video.addEventListener('play', updateIcons);
                video.addEventListener('pause', updateIcons);

                const observer = new IntersectionObserver(function(entries) {
                    entries.forEach(function(entry) {
                        if (entry.isIntersecting && !userPaused) {
                            video.play().then(() => {
                                fadeInVolume(video);
                            }).catch(() => {
                                video.muted = true;
                                video.play().catch(() => {});
                            });
                        } else if (!entry.isIntersecting) {
                            fadeOutVolume(video);
                        }
                    });
                }, { threshold: 0.4 });

                observer.observe(video);
            });
        }
    </script>
    <script>
        // Activar animación del banner cada vez que entra/sale del viewport
        if (typeof window !== 'undefined') {
            window.addEventListener('load', function() {
                const bannerSection = document.getElementById('product-splash-banner');
                const bannerContent = document.getElementById('banner-content');
                
                if (bannerSection && bannerContent) {
                    const observer = new IntersectionObserver(function(entries) {
                        entries.forEach(function(entry) {
                            if (entry.isIntersecting) {
                                // Agregar clase de animación cuando entra
                                bannerContent.classList.remove('banner-animate');
                                // Force reflow para reiniciar la animación
                                void bannerContent.offsetWidth;
                                bannerContent.classList.add('banner-animate');
                            } else {
                                // Quitar clase cuando sale para poder reanimar
                                bannerContent.classList.remove('banner-animate');
                            }
                        });
                    }, { 
                        root: null,
                        threshold: 0.1,
                        rootMargin: '0px'
                    });
                    
                    observer.observe(bannerSection);
                }
            });
        }
    </script>
    <script>
        if (typeof window !== 'undefined') {
            window.addEventListener('load', function () {
                const carousel = document.querySelector<HTMLElement>('[data-carousel]');
                if (!carousel) return;

                const slides = Array.from(carousel.querySelectorAll<HTMLElement>('.carousel-slide'));
                const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-carousel-dot]'));
                let currentIndex = 0;
                let timerId: ReturnType<typeof setInterval> | null = null;

                const activate = (index: number) => {
                    slides.forEach((slide, idx) => {
                        slide.classList.toggle('is-active', idx === index);
                    });
                    dots.forEach((dot, idx) => {
                        dot.classList.toggle('is-active', idx === index);
                    });
                    currentIndex = index;
                };

                const nextSlide = () => {
                    const nextIndex = (currentIndex + 1) % slides.length;
                    activate(nextIndex);
                };

                const startAutoplay = () => {
                    stopAutoplay();
                    timerId = setInterval(nextSlide, 4500);
                };

                const stopAutoplay = () => {
                    if (timerId) {
                        clearInterval(timerId);
                        timerId = null;
                    }
                };

                dots.forEach((dot) => {
                    dot.addEventListener('click', () => {
                        const targetIndex = Number(dot.dataset.carouselDot);
                        activate(targetIndex);
                        startAutoplay();
                    });
                });

                activate(0);
                startAutoplay();

                carousel.addEventListener('mouseenter', stopAutoplay);
                carousel.addEventListener('mouseleave', startAutoplay);
            });
        }
    </script>
    <style is:global>
