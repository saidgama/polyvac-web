---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
const title = "Industrias Polyvac";
const description = "Inicio de la pagina.";

import CategoryCard from "../components/CategoryCard.astro";
import ProductCardSmall from "../components/ProductCardSmall.astro";

import bgHero from "../assets/hero/color-explosion.jpg";
import logoHero from "../assets/hero/HeroImage.png";
import Badge from "../components/Badge.astro";
import oekotexLogo from '../assets/acercade/oekotex.png';
import bluesignLogo from '../assets/acercade/bluesign.png';  
import bureauVeritasLogo from '../assets/acercade/bureau.png';
import productBanner from '../assets/index/productbanner.png';

// Importar productos locales
import productos from '../data/productos.js';

// Obtener los primeros 4 productos como destacados
const productosDestacados = productos.slice(0, 4);

// Imagen para la categoría de estampado
import estampadoImage from '../assets/card1.png';
// Imagen de cubeta para productos
import cubetaImage from '../assets/cubeta.png';
---

<Layout title={title} description={description}>
    <section class="hero-section" id="home">
        <div class="hero-background"></div>
        <canvas id="lava-lamp-canvas"></canvas>
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="badge">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M10 3.5a1.5 1.5 0 011.06.44l5.25 5.25a1.5 1.5 0 010 2.12l-5.25 5.25a1.5 1.5 0 01-2.12 0L3.94 11.31a1.5 1.5 0 010-2.12l5.25-5.25A1.5 1.5 0 0110 3.5zm0 2.12L6.12 9.5h7.76L10 5.62z" />
                </svg>
                <span>Soluciones Químicas Profesionales</span>
            </div>
            <h1>Expertos en Color: <br> <span class="text-yellow-400">Químicos para la Industria</span></h1>
            <p>Fabricamos y distribuimos una amplia gama de productos químicos, resinas, pigmentos y colorantes, ofreciendo soluciones integrales para la industria del color.</p>
            <div class="hero-buttons">
                <a href="/estampado" class="btn btn-primary">
                    Explorar Catalogo
                    <svg class="arrow-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                </a>
                <a href="/contacto" class="btn btn-secondary">Contacto</a>
            </div>
            <div class="hero-stats">
                <div>
                    <span class="stat-number">500+</span>
                    <span class="stat-label">Productos</span>
                </div>
                <div>
                    <span class="stat-number">20+</span>
                    <span class="stat-label">Años de Experiencia</span>
                </div>
            </div>
        </div>
    </section>
    <section>
        <!-- Sección de cards de categorias -->
    <Badge text="Nuestras Líneas de Productos"/>

     <CategoryCard
        imageUrl={estampadoImage}
        altText="Línea de productos para estampación textil"
        title="Línea de Estampado"
        description="Tintas, pigmentos, colorantes, auxiliares y accesorios para estampado."
        buttonLabel="Ver Catalogo"
        buttonHref="/estampado"
        position="right"
    />

    </section>

    <!-- Banner intermedio bajo la línea de productos -->
    <section id="product-splash-banner" class="relative overflow-hidden">
        <!-- Fondo con gradiente azul y blur -->
        <div class="absolute inset-0 -z-10">
            <div class="absolute inset-0 bg-gradient-to-r from-blue-800 via-blue-700 to-blue-900"></div>
            <div class="absolute -inset-16 bg-gradient-to-tr from-blue-400/40 via-cyan-400/30 to-indigo-400/40 blur-3xl opacity-80"></div>
        </div>
        <div class="relative mx-auto max-w-7xl px-0 sm:px-6 lg:px-8">
            <div class="relative h-64 sm:h-72 md:h-80 lg:h-96 xl:h-[28rem]">
                <div id="banner-content" class="absolute inset-0 w-full h-full">
                    <Image
                        src={productBanner}
                        alt="Banner Polyvac"
                        class="w-full h-full object-cover object-center select-none"
                        draggable="false"
                    />
                </div>
            </div>
        </div>
    </section>
    
    <Badge text="Productos destacados" />

    <!-- Sección de productos destacados -->
    <div class="mx-auto max-w-7xl px-4 py-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {productosDestacados.map(producto => (
                <div class="bg-white rounded-lg shadow-2xl overflow-hidden max-w-sm mx-auto font-fuenteprincipal">
                    <!-- Imagen del producto -->
                    <div class="relative h-64">
                        <Image 
                            src={cubetaImage} 
                            alt={`Imagen de ${producto.titulo}`}
                            class="w-full h-64 object-cover"
                        />
                        <div 
                            class="absolute bottom-0 left-0 px-6 py-4 z-10 flex items-center justify-center min-w-[140px]"
                            style={`background-color: ${producto.colorPrincipal}; opacity: 0.9; clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 50%, calc(100% - 20px) 100%, 0 100%);`}
                        >
                            <div class="text-center">
                                <span class="text-white text-sm font-light block">Linea</span>
                                <span class="text-white text-lg font-bold leading-tight">{producto.titulo}</span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Contenido -->
                    <div class="p-4">
                        <a
                            href={`/producto/${producto.id}`}
                            class="inline-flex items-center justify-center bg-azulprimario text-white text-base font-medium px-6 py-3 w-full hover:bg-blue-700 transition-colors"
                        >
                            Ver Producto
                        </a>
                    </div>
                </div>
            ))}
        </div>
    </div>

    <!-- Certificaciones -->
    <section class="py-16 mt-15 overflow-hidden">
        <div class="mb-12 px-4">
            <h2 class="text-4xl md:text-5xl font-bold text-center mb-4 bg-gradient-to-r from-green-500 via-blue-500 to-red-500 bg-clip-text text-transparent">
                CERTIFICACIONES Y NORMAS
            </h2>
            <p class="text-center text-lg md:text-xl font-medium max-w-3xl mx-auto bg-gradient-to-r from-gray-600 to-gray-800 bg-clip-text text-transparent">
                Todos nuestros productos cumplen con las normas requeridas por:
            </p>
        </div>
        
        <div class="grid md:grid-cols-3 gap-0">
            <!-- OEKOTEX 2024 - Verde -->
            <div class="relative py-16 px-8 text-center min-h-[450px] flex flex-col justify-center items-center transition-all duration-300 hover:scale-105">
                <!-- Fondo con gradiente verde -->
                <div class="absolute inset-0 bg-gradient-to-br from-green-400 via-green-500 to-emerald-600 opacity-85"></div>
                
                <!-- Contenido -->
                <div class="relative z-10">
                    <div class="w-40 h-40 bg-white rounded-2xl flex items-center justify-center mx-auto mb-6 p-6 shadow-2xl transform transition-transform hover:rotate-3">
                        <Image 
                            src={oekotexLogo} 
                            alt="Logo OEKOTEX 2024" 
                            class="w-full h-full object-contain"
                        />
                    </div>
                    <h3 class="text-3xl font-bold text-white mb-2 drop-shadow-lg">OEKOTEX</h3>
                    <h4 class="text-2xl font-bold text-green-100 mb-4">2024</h4>
                    <p class="text-base text-white max-w-xs mx-auto drop-shadow-md">
                        Estándar internacional para textiles libres de sustancias nocivas
                    </p>
                </div>
            </div>

            <!-- BLUESIGN - Azul -->
            <div class="relative py-16 px-8 text-center min-h-[450px] flex flex-col justify-center items-center transition-all duration-300 hover:scale-105">
                <!-- Fondo con gradiente azul -->
                <div class="absolute inset-0 bg-gradient-to-br from-blue-400 via-blue-600 to-indigo-700 opacity-85"></div>
                
                <!-- Contenido -->
                <div class="relative z-10">
                    <div class="w-40 h-40 bg-white rounded-2xl flex items-center justify-center mx-auto mb-6 p-6 shadow-2xl transform transition-transform hover:rotate-3">
                        <Image 
                            src={bluesignLogo} 
                            alt="Logo Bluesign" 
                            class="w-full h-full object-contain"
                        />
                    </div>
                    <h3 class="text-3xl font-bold text-white mb-2 drop-shadow-lg">BLUESIGN</h3>
                    <h4 class="text-2xl font-bold text-blue-100 mb-4">APPROVED</h4>
                    <p class="text-base text-white max-w-xs mx-auto drop-shadow-md">
                        Sistema de gestión para una producción textil sostenible
                    </p>
                </div>
            </div>

            <!-- BUREAU VERITAS - Rojo -->
            <div class="relative py-16 px-8 text-center min-h-[450px] flex flex-col justify-center items-center transition-all duration-300 hover:scale-105">
                <!-- Fondo con gradiente rojo -->
                <div class="absolute inset-0 bg-gradient-to-br from-red-400 via-red-600 to-rose-700 opacity-85"></div>
                
                <!-- Contenido -->
                <div class="relative z-10">
                    <div class="w-40 h-40 bg-white rounded-2xl flex items-center justify-center mx-auto mb-6 p-6 shadow-2xl transform transition-transform hover:rotate-3">
                        <Image 
                            src={bureauVeritasLogo} 
                            alt="Logo Bureau Veritas" 
                            class="w-full h-full object-contain"
                        />
                    </div>
                    <h3 class="text-3xl font-bold text-white mb-2 drop-shadow-lg">BUREAU</h3>
                    <h4 class="text-3xl font-bold text-red-100 mb-4">VERITAS</h4>
                    <p class="text-base text-white max-w-xs mx-auto drop-shadow-md">
                        Líder mundial en servicios de inspección, certificación y ensayos
                    </p>
                </div>
            </div>
        </div>
    </section>
    <script is:inline src="/js/lava-lamp.js"></script>
    <script>
        // Activar animación del banner cada vez que entra/sale del viewport
        if (typeof window !== 'undefined') {
            window.addEventListener('load', function() {
                const bannerSection = document.getElementById('product-splash-banner');
                const bannerContent = document.getElementById('banner-content');
                
                if (bannerSection && bannerContent) {
                    const observer = new IntersectionObserver(function(entries) {
                        entries.forEach(function(entry) {
                            if (entry.isIntersecting) {
                                // Agregar clase de animación cuando entra
                                bannerContent.classList.remove('banner-animate');
                                // Force reflow para reiniciar la animación
                                void bannerContent.offsetWidth;
                                bannerContent.classList.add('banner-animate');
                            } else {
                                // Quitar clase cuando sale para poder reanimar
                                bannerContent.classList.remove('banner-animate');
                            }
                        });
                    }, { 
                        root: null,
                        threshold: 0.1,
                        rootMargin: '0px'
                    });
                    
                    observer.observe(bannerSection);
                }
            });
        }
    </script>
    <style is:global>
        /* Estado inicial: oculto abajo */
        #banner-content {
            opacity: 0;
            transform: translateY(100%);
        }
        
        /* Animación del banner: sube desde abajo con fade */
        .banner-animate {
            animation-name: fadeInBottom;
            animation-duration: 1.2s;
            animation-fill-mode: both;
        }
        
        @keyframes fadeInBottom {
            from {
                opacity: 0;
                transform: translateY(100%);
            }
            to { 
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</Layout>

