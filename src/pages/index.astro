            padding: 0.5rem 0.75rem;
            background: linear-gradient(transparent, rgba(0,0,0,0.7));
            opacity: 0;
            transition: opacity 0.3s;
        }
        .hero-video-container:hover .hero-video-controls {
            opacity: 1;
        }
        .vid-btn {
