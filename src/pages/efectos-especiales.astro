---
import Layout from "../layouts/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
import TablaColores from "../components/TablaColores.astro";
import products from "../data/efectos-especiales.js";

// Importar imágenes
import bannerImage from '../assets/hero/test.png';

const title = "Efectos Especiales - Industrias Polyvac";
---

<Layout title={title} description="Catálogo de productos para efectos especiales: Flock, Micas y Glitters">
    <PageBanner 
        imageUrl={bannerImage}
        titulo="Efectos Especiales"
    />
    
    <div class="container mx-auto px-4 py-12">
        <div class="max-w-4xl mx-auto space-y-16">
            <p class="text-lg text-gray-700 text-center mb-10">
                Lleva tus diseños al siguiente nivel con nuestra gama de efectos especiales.

            {products.map((producto) => (
                <section id={producto.id} class="bg-white rounded-xl shadow-md p-6">
                    <div class="flex flex-col md:flex-row gap-8 items-start">
                         {/* Imagen principal del producto */}
                         <div class="w-full md:w-1/3 flex justify-center">
                            <img 
                                src={producto.imagenes[0].src} 
                                alt={producto.titulo}
                                class="w-48 h-48 object-contain"
                            />
                         </div>

                         {/* Contenido descriptivo */}
                         <div class="w-full md:w-2/3">
                            <h2 class="text-3xl font-bold text-gray-800 mb-4">{producto.titulo}</h2>
                            <p class="text-gray-600 mb-6 text-lg text-justify">{producto.descripcion}</p>
                            
                            <button 
                                id={`btn-${producto.id}`}
                                class="toggle-table-btn group flex items-center gap-2 bg-azulprimario text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition-colors font-semibold"
                                data-target={`table-${producto.id}`}
                            >
                                <span>Ver Linea </span>
                                <svg class="w-5 h-5 transform group-hover:rotate-90 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                            </button>
                        </div>
                    </div>

                    {/* Tabla Colores (Inicialmente oculta) */}
                    {producto.colores && producto.colores.length > 0 && (
                        <div id={`table-${producto.id}`} class="hidden mt-8 border-t pt-8 transition-all duration-300">
                             <TablaColores 
                                titulo={`Tabla de ${producto.titulo}`} 
                                colorantes={producto.colores}
                             />
                        </div>
                    )}
                </section>
            ))}
        </div>
    </div>
</Layout>

<script>
    // Lógica para mostrar/ocultar tablas
    const buttons = document.querySelectorAll('.toggle-table-btn');
    buttons.forEach(btn => {
        btn.addEventListener('click', () => {
             const targetId = btn.getAttribute('data-target');
             const targetContent = document.getElementById(targetId);
             
             if(targetContent) {
                 targetContent.classList.toggle('hidden');
                 const isHidden = targetContent.classList.contains('hidden');
                 const span = btn.querySelector('span');
                 span.textContent = isHidden ? 'Ver Linea' : 'Ocultar Tabla';
                 
                 // Rotación de flecha
                 const svg = btn.querySelector('svg');
                 if(svg) {
                    if (!isHidden) {
                        svg.classList.add('rotate-90');
                    } else {
                        svg.classList.remove('rotate-90');
                    }
                 }
             }
        });
    });
</script>
