---
import Badge from "../components/Badge.astro";
import Layout from "../layouts/Layout.astro";
import productos from "../data/productos.js";

const title = "Búsqueda - Industrias Polyvac";
const description = "Página para búsqueda";

// Preparar productos para el cliente (sin imágenes que son objetos)
const productosParaCliente = productos.map(p => ({
  id: p.id,
  titulo: p.titulo,
  descripcion: p.descripcion,
  categoria: p.categoria,
  colorPrincipal: p.colorPrincipal
}));

// Obtener query de la URL para SEO fallback
const url = Astro.url;
const query = url.searchParams.get('q') || '';
---

<Layout title={title} description={description}>
  <div class="my-15">
    <Badge text="Búsqueda" />
  </div>

  <div class="container mx-auto px-4 py-8">
    <!-- Formulario de búsqueda -->
    <div class="max-w-2xl mx-auto mb-8">
      <form id="search-form" class="flex gap-4">
        <input 
          type="text" 
          id="search-input"
          name="q" 
          value={query}
          placeholder="Buscar productos..." 
          class="flex-1 px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
        />
        <button 
          type="submit"
          class="px-6 py-3 bg-azulprimario rounded-lg text-white hover:bg-blue-700 transition-colors"
        >
          Buscar
        </button>
      </form>
    </div>

    <!-- Resultados -->
    <div id="search-results">
      <!-- Placeholder para búsqueda del cliente -->
      <div id="client-results" class="hidden">
        <h2 id="results-title" class="text-2xl font-bold mb-6"></h2>
        <div id="results-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"></div>
        <div id="no-results" class="text-center py-12 hidden">
          <p class="text-gray-600 text-lg">No se encontraron productos</p>
          <p class="text-gray-500 mt-2">Intenta con otros términos de búsqueda</p>
        </div>
      </div>

      <!-- Estado inicial -->
      <div id="initial-state" class="text-center py-12" style={query ? "display: none;" : ""}>
        <p class="text-gray-600 text-lg">
          Ingresa un término de búsqueda para encontrar productos
        </p>
      </div>
    </div>
  </div>

  <!-- Pasar datos al cliente -->
  <script type="module" define:vars={{ productosParaCliente, query }}>
    // Productos locales para búsqueda
    const productos = productosParaCliente;
    
    // Función para normalizar texto (quitar acentos, minúsculas)
    function normalizeString(str) {
      return str
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9\s]/g, '');
    }
    
    // Función de búsqueda local
    function searchProductos(queryText) {
      const normalizedQuery = normalizeString(queryText);
      const queryWords = normalizedQuery.split(/\s+/).filter(w => w.length > 1);
      
      return productos
        .map(producto => {
          let score = 0;
          const normalizedTitle = normalizeString(producto.titulo);
          const normalizedDesc = normalizeString(producto.descripcion || '');

          // Coincidencia exacta en título (mayor peso)
          if (normalizedTitle.includes(normalizedQuery)) {
            score += 100;
          }

          // Coincidencia por palabras en título
          queryWords.forEach(word => {
            if (normalizedTitle.includes(word)) {
              score += 50;
            }
          });

          // Coincidencia en descripción
          if (normalizedDesc.includes(normalizedQuery)) {
            score += 30;
          }

          // Coincidencia por palabras en descripción
          queryWords.forEach(word => {
            if (normalizedDesc.includes(word)) {
              score += 15;
            }
          });

          return { ...producto, score };
        })
        .filter(producto => producto.score > 0)
        .sort((a, b) => b.score - a.score);
    }
    
    // Función de inicialización
    function initializeSearch() {
      const searchForm = document.getElementById('search-form');
      const searchInput = document.getElementById('search-input');
      
      if (!searchForm || !searchInput) {
        return;
      }
      
      // Event listener para el formulario
      searchForm.addEventListener('submit', function(e) {
        e.preventDefault();
        const queryValue = searchInput.value.trim();
        
        if (queryValue && queryValue.length >= 2) {
          performSearch(queryValue);
        } else if (queryValue.length === 0) {
          showInitialState();
        }
      });
      
      // Event listener para búsqueda en tiempo real
      searchInput.addEventListener('input', function(e) {
        const queryValue = e.target.value.trim();
        
        if (queryValue.length >= 2) {
          performSearch(queryValue);
        } else if (queryValue.length === 0) {
          showInitialState();
        }
      });
      
      // Si hay query inicial, hacer búsqueda
      if (query && query.trim().length >= 2) {
        performSearch(query.trim());
      }
    }
    
    function performSearch(queryText) {
      const initialState = document.getElementById('initial-state');
      const clientResults = document.getElementById('client-results');
      
      if (initialState) initialState.style.display = 'none';
      if (clientResults) clientResults.classList.remove('hidden');
      
      // Buscar en productos locales
      const results = searchProductos(queryText);
      
      // Mostrar resultados
      displayResults(queryText, results);
      
      // Actualizar URL
      const newUrl = new URL(window.location);
      newUrl.searchParams.set('q', queryText);
      window.history.replaceState({}, '', newUrl);
    }
    
    function displayResults(queryText, results) {
      const resultsTitle = document.getElementById('results-title');
      const resultsGrid = document.getElementById('results-grid');
      const noResults = document.getElementById('no-results');
      
      if (resultsTitle) {
        resultsTitle.textContent = `Resultados para: "${queryText}" (${results.length} productos encontrados)`;
      }
      
      if (results.length > 0) {
        if (resultsGrid) {
          resultsGrid.innerHTML = renderProductCards(results);
          resultsGrid.classList.remove('hidden');
        }
        if (noResults) noResults.classList.add('hidden');
      } else {
        if (resultsGrid) resultsGrid.classList.add('hidden');
        if (noResults) {
          noResults.innerHTML = `
            <div class="text-center py-12">
              <p class="text-gray-600 text-lg">No se encontraron productos para "${queryText}"</p>
              <div class="text-gray-500 mt-4 space-y-2">
                <p class="text-sm">💡 Consejos para mejorar tu búsqueda:</p>
                <ul class="text-xs space-y-1">
                  <li>• Verifica la ortografía</li>
                  <li>• Usa términos más generales</li>
                  <li>• Prueba con sinónimos</li>
                </ul>
              </div>
            </div>
          `;
          noResults.classList.remove('hidden');
        }
      }
    }
    
    function renderProductCards(results) {
      return results.map((product) => {
        const colorStyle = product.colorPrincipal ? `background-color: ${product.colorPrincipal};` : 'background-color: #3b82f6;';
        
        return `
          <a href="/producto/${product.id}" class="block bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1">
            <div class="aspect-square bg-gray-100 relative overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-32 h-32 rounded-full opacity-20" style="${colorStyle}"></div>
              </div>
              <div class="absolute bottom-0 left-0 right-0 p-3" style="${colorStyle} opacity: 0.9;">
                <h3 class="font-bold text-white text-sm line-clamp-2">${product.titulo}</h3>
              </div>
            </div>
            <div class="p-4">
              <p class="text-sm text-gray-600 mb-3 line-clamp-3">${product.descripcion || ''}</p>
              <div class="flex items-center justify-between">
                <span class="inline-block bg-gray-100 text-gray-700 text-xs px-2 py-1 rounded-full">${product.categoria}</span>
                <span class="text-azulprimario text-sm font-medium">Ver detalles →</span>
              </div>
            </div>
          </a>
        `;
      }).join('');
    }
    
    function showInitialState() {
      const clientResults = document.getElementById('client-results');
      const initialState = document.getElementById('initial-state');
      
      if (clientResults) clientResults.classList.add('hidden');
      if (initialState) initialState.style.display = 'block';
    }
    
    // Inicializar cuando el script se cargue
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initializeSearch);
    } else {
      initializeSearch();
    }
  </script>
</Layout>
