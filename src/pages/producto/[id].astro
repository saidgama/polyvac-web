---
import { Image } from "astro:assets";
import Layout from '../../layouts/Layout.astro';
import TablaColores from '../../components/TablaColores.astro';
import TablaEspecificaciones from '../../components/TablaEspecificaciones.astro';
import productos from '../../data/productos.js';

// Función para generar rutas estáticas usando nuestra base de datos dummy
export async function getStaticPaths() {
  return productos.map((producto) => ({
    params: { id: producto.id }
  }));
}

// Obtener el ID de los parámetros
const { id } = Astro.params;

// Buscar el producto en nuestra base de datos
const producto = productos.find(p => p.id === id);

// Verificar que el producto existe
if (!producto) {
  return Astro.redirect('/404');
}

const title = producto.titulo;
const description = producto.descripcion;

// Flag para ocultar todo lo relacionado a Ficha Técnica
const ocultarFichaTecnica = true;

// Mapeo de subcategorías para mostrar breadcrumbs
const subcategoriasNombres = {
  1: "Aplicación",
  2: "Formulación", 
  3: "Materias primas",
  4: "Accesorios"
};

// Mapeo de taxonomías para mostrar etiquetas
const taxonomiasNombres = {
  1: "Para algodón",
  2: "Para poliéster", 
  3: "Para fondos claros",
  4: "Para fondos oscuros",
  5: "Efectos especiales",
  7: "Tintas plastisol",
  8: "Tintas base agua",
  9: "Tintas de sublimación",
  10: "Tintas DTF",
  11: "Pigmentos",
  12: "Colorantes",
  13: "Auxiliares textiles",
  14: "Acabados especiales",
  15: "Marcos",
  16: "Mallas",
  17: "Raseros",
  18: "Emulsiones"
};
---

<Layout title={title} description={description}>
  <!-- Hero section con fondo gris claro -->
  <section class="bg-gray-200 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Imagen del producto -->
        <div>
          <div class="relative w-3/4 aspect-square bg-white rounded-xl shadow-lg overflow-hidden flex items-center justify-center border border-gray-200 mx-auto">
            <div class="absolute bottom-0 left-0 px-4 py-4 md:px-8 md:py-6 z-10 flex items-center justify-center bg-azulprimario"
              style="opacity: 0.9; clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 50%, calc(100% - 20px) 100%, 0 100%); min-width: 180px; max-width: 85%; min-height: 60px;">
              <div class="text-center px-2 md:px-3">
                <span class="text-white text-xl md:text-2xl font-bold leading-tight">{producto.titulo}</span>
              </div>
            </div>
            <Image 
              src={producto.imagenes[0]} 
              alt={producto.titulo}
              width={533}
              height={492}
              class="object-contain w-full h-full p-6" 
            />
          </div>
        </div>
        
        <!-- Información del producto -->
        <div class="space-y-6">
          <!-- Breadcrumb -->
          <nav class="text-sm text-gray-500">
            <a href="/" class="hover:text-azulprimario transition-colors">Inicio</a>
            <span class="mx-2">/</span>
            <a href="/estampado" class="hover:text-azulprimario transition-colors">Línea de Estampado</a>
            <span class="mx-2">/</span>
            <span class="text-azulprimario font-semibold">{producto.titulo}</span>
          </nav>
          
          <!-- Título y descripción -->
          <div>
            <h1 class="text-3xl lg:text-4xl font-bold text-azulsecundario mb-4">{producto.titulo}</h1>
            <p class="text-gray-600 text-lg leading-relaxed">{producto.descripcion}</p>
          </div>

          <!-- Etiquetas de taxonomías -->
          <div class="space-y-3">
            <h3 class="text-lg font-semibold text-azulsecundario">Características:</h3>
            <div class="flex flex-wrap gap-2">
              {producto.taxonomias.map(taxonomiaId => (
                <span class="px-3 py-1 bg-azulprimario text-white text-sm rounded-full">
                  {taxonomiasNombres[taxonomiaId as keyof typeof taxonomiasNombres]}
                </span>
              ))}
            </div>
          </div>

          <!-- Subcategorías -->
          <div class="space-y-3">
            <h3 class="text-lg font-semibold text-azulsecundario">Categorías:</h3>
            <div class="flex flex-wrap gap-2">
              {producto.subcategorias.map(subcategoriaId => (
                <span class="px-3 py-1 bg-gray-200 text-gray-700 text-sm rounded-full">
                  {subcategoriasNombres[subcategoriaId as keyof typeof subcategoriasNombres]}
                </span>
              ))}
            </div>
          </div>

          <!-- Botones de acción -->
          <div class="flex justify-start pt-6">
            {!ocultarFichaTecnica && producto.fichaTecnica && (
              <a 
                href={producto.fichaTecnica} 
                target="_blank"
                class="bg-azulprimario text-white py-3 px-6 rounded-lg hover:bg-blue-700 transition-colors font-semibold inline-flex items-center"
              >
                📄 Descargar Ficha Técnica
              </a>
            )}
            {producto.esTablaColores && !producto.fichaTecnica && (
              <div class="bg-green-100 text-green-800 py-3 px-6 rounded-lg font-semibold">
                📊 Ver tabla de colores completa abajo
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección de colores disponibles -->
  {producto.colores && producto.colores.length > 0 && !producto.esTablaColores && (
    <section class="bg-gray-200 py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-azulsecundario mb-4">Gama de colores</h2>
          <div class="w-20 h-1 bg-azulprimario mx-auto"></div>
        </div>
        
        <div class="bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden mx-auto max-w-2xl">
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-azulprimario text-white">
                <tr>
                  <th class="px-4 py-3 text-left text-base font-semibold">Nombre</th>
                  <th class="px-4 py-3 text-left text-base font-semibold">Color</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200">
                {producto.colores.map((color, index) => (
                  <tr class={`${index % 2 === 0 ? 'bg-white' : 'bg-gray-50'} hover:bg-gray-100 transition-colors`}>
                    <td class="px-4 py-3 text-gray-900 font-medium">{color.nombre}</td>
                    <td class="px-4 py-3">
                      <div class="flex items-center gap-2">
                        <div 
                          class="w-24 h-12 rounded-lg border-2 border-gray-300 shadow-sm"
                          style={`background-color: ${color.hex}`}
                          title={`${color.nombre} - ${color.hex}`}
                        ></div> 
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Sección de tabla de colores completa (para productos de colorantes) -->
  {producto.esTablaColores && producto.colores && producto.colores.length > 0 && (
    <section class="bg-gray-50 py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-azulsecundario mb-4">Tabla de Colores Completa</h2>
          <div class="w-20 h-1 bg-azulprimario mx-auto"></div>
          <p class="text-gray-600 mt-4">Especificaciones técnicas y propiedades de cada colorante</p>
        </div>
        
        <TablaColores 
          colorantes={producto.colores} 
          titulo={`Tabla de colores - ${producto.titulo}`}
        />
      </div>
    </section>
  )}

  <!-- Sección de tabla de especificaciones (para mallas y productos técnicos) -->
  {producto.esTablaEspecificaciones && producto.items && producto.items.length > 0 && (
    <section class="bg-gray-50 py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-azulsecundario mb-4">Especificaciones Técnicas</h2>
          <div class="w-20 h-1 bg-azulprimario mx-auto"></div>
          <p class="text-gray-600 mt-4">Detalles técnicos y características del producto</p>
        </div>
        
        <TablaEspecificaciones 
          items={producto.items} 
          titulo={`Especificaciones - ${producto.titulo}`}
        />
      </div>
    </section>
  )}

  <!-- Sección de visualización del PDF -->
  {!ocultarFichaTecnica && producto.fichaTecnica && (
    <section class="bg-gray-200 py-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-azulsecundario mb-4">Ficha Técnica</h2>
          <div class="w-20 h-1 bg-azulprimario mx-auto"></div>
          <p class="text-gray-600 mt-4">Consulta todos los detalles técnicos y especificaciones del producto</p>
        </div>
        
        <div class="bg-gray-50 rounded-xl p-4 shadow-lg border border-gray-200">
          <iframe 
            src={`https://docs.google.com/viewer?url=${encodeURIComponent(producto.fichaTecnica)}&embedded=true`}
            class="w-full h-[400px] md:h-[600px] xl:h-[700px] rounded-lg border border-gray-300" 
            title={`Ficha técnica de ${producto.titulo}`}
            allowfullscreen
            frameborder="0"
          ></iframe>
        </div>
      </div>
    </section>
  )}
</Layout>
