---
import Layout from "../layouts/Layout.astro"
import PageBanner from "../components/PageBanner.astro";
import bg from '../assets/acercade/acercabg.png';
import Badge from "../components/Badge.astro";
import { Image } from "astro:assets";
import img2 from '../assets/acercade/img2.jpg';
import objetivo from '../assets/acercade/vision.jpg';
import mision from '../assets/acercade/mision.jpg';
// Logos para certificaciones
import oekotexLogo from '../assets/acercade/oekotex.png';
import bluesignLogo from '../assets/acercade/bluesign.png';  
import bureauVeritasLogo from '../assets/acercade/bureau.png';
const title = "Nosotros - Industrias Polyvac";
const description = "Pagina para descubrir acerca de la empresa.";
---

<Layout title={title} description={description}>
    <PageBanner imageUrl={bg} titulo="Acerca de nosotros"/>
    
    <!-- Contenido principal -->
    <div class="font-fuenteprincipal">
        
        <!-- Historia (hero de la sección) -->
        <section class="py-16 rainbow-bg">
            <div class="max-w-7xl mx-auto px-4">
                <div class="grid lg:grid-cols-2 gap-10 items-center">
                    <!-- Video (lado izquierdo) -->
                    <div class="relative">
                        <div class="w-full h-72 sm:h-96 lg:h-[560px] overflow-hidden rounded-xl bg-gray-100 ring-4 ring-white/20">
                            <video
                                class="w-full h-full object-cover"
                                src="/videos/video_aboutus.mp4"
                                autoplay
                                muted
                                loop
                                preload="metadata"
                                playsinline
                            ></video>
                        </div>

                        <!-- Experiencia (badge flotante) -->
                        <div class="absolute -top-6 left-6 bg-rojo text-white px-6 py-4 rounded-xl border border-white/20">
                            <div class="flex items-end gap-3">
                                <div class="text-4xl md:text-5xl font-extrabold leading-none">25+</div>
                                <div class="text-sm md:text-base leading-tight">
                                    <div class="font-semibold">Años</div>
                                    <div>de experiencia</div>
                                </div>
                            </div>
                        </div>

                        <!-- Acento decorativo (color) -->
                    </div>

                    <!-- Contenido (lado derecho) -->
                    <div class="bg-white/95 backdrop-blur rounded-2xl p-6 md:p-10 border border-white/30">
                        <div class="inline-flex items-center px-4 py-2 bg-azulprimario text-white font-semibold rounded">
                            ACERCA DE NOSOTROS
                        </div>

                        <h2 class="mt-5 text-3xl md:text-5xl font-extrabold text-gray-900 leading-tight">
                            Industrias Polyvac: color, calidad y soporte técnico
                        </h2>

                        <p class="mt-5 text-gray-700 md:text-lg leading-relaxed">
                            <span class="font-bold text-azulsecundario">INDUSTRIAS POLYVAC S. A. DE C. V.</span> desarrolla y distribuye soluciones para la industria textil y la serigrafía, con enfoque en innovación, confiabilidad y atención técnica.
                        </p>

                        <!-- "Tab" / sección destacada -->
                        <div class="mt-8">
                            <div class="inline-flex items-center justify-center px-6 py-3 bg-white rounded border border-azulprimario/20">
                                <span class="font-semibold text-azulprimario">Nuestra Historia</span>
                            </div>
                            <div class="h-1 w-40 bg-rojo mt-3"></div>
                        </div>

                        <p class="mt-6 text-gray-600 leading-relaxed">
                            Empresa fundada en el año de 1998, iniciándose en la distribución y fabricación de una amplia gama de productos: químicos, colorantes, pigmentos, resinas, pintura para el estampado, auxiliares para la industria textil, serigrafía y sus derivados.
                        </p>

                        <p class="mt-4 text-gray-600 leading-relaxed">
                            Nos enfocamos en aportar valor a nuestros clientes con soporte técnico, innovación y un control de calidad riguroso en cada etapa.
                        </p>

                        <div class="mt-8 grid sm:grid-cols-2 gap-4 text-gray-800">
                            <div class="flex items-start gap-3">
                                <span class="mt-1 inline-flex items-center justify-center w-6 h-6 rounded-full border border-rojo text-rojo">
                                    <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M16.704 5.29a1 1 0 010 1.415l-7.5 7.5a1 1 0 01-1.415 0l-3.5-3.5a1 1 0 011.415-1.415l2.793 2.793 6.793-6.793a1 1 0 011.414 0z" clip-rule="evenodd" />
                                    </svg>
                                </span>
                                <span class="font-semibold">Sistema de control de calidad</span>
                            </div>

                            <div class="flex items-start gap-3">
                                <span class="mt-1 inline-flex items-center justify-center w-6 h-6 rounded-full border border-azulsecundario text-azulsecundario">
                                    <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M16.704 5.29a1 1 0 010 1.415l-7.5 7.5a1 1 0 01-1.415 0l-3.5-3.5a1 1 0 011.415-1.415l2.793 2.793 6.793-6.793a1 1 0 011.414 0z" clip-rule="evenodd" />
                                    </svg>
                                </span>
                                <span class="font-semibold">Soporte técnico especializado</span>
                            </div>

                            <div class="flex items-start gap-3">
                                <span class="mt-1 inline-flex items-center justify-center w-6 h-6 rounded-full border border-azulprimario text-azulprimario">
                                    <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M16.704 5.29a1 1 0 010 1.415l-7.5 7.5a1 1 0 01-1.415 0l-3.5-3.5a1 1 0 011.415-1.415l2.793 2.793 6.793-6.793a1 1 0 011.414 0z" clip-rule="evenodd" />
                                    </svg>
                                </span>
                                <span class="font-semibold">Innovación en tintas y auxiliares</span>
                            </div>

                            <div class="flex items-start gap-3">
                                <span class="mt-1 inline-flex items-center justify-center w-6 h-6 rounded-full border border-rojo text-rojo">
                                    <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M16.704 5.29a1 1 0 010 1.415l-7.5 7.5a1 1 0 01-1.415 0l-3.5-3.5a1 1 0 011.415-1.415l2.793 2.793 6.793-6.793a1 1 0 011.414 0z" clip-rule="evenodd" />
                                    </svg>
                                </span>
                                <span class="font-semibold">Compromiso con soluciones más sustentables</span>
                            </div>
                        </div>

                        <!-- Chips (acentos de color) -->
                        <div class="mt-8 flex flex-wrap gap-3">
                            <span class="px-4 py-2 rounded-full bg-rojo/10 text-rojo font-semibold">Químicos</span>
                            <span class="px-4 py-2 rounded-full bg-azulprimario/10 text-azulprimario font-semibold">Colorantes</span>
                            <span class="px-4 py-2 rounded-full bg-azulsecundario/10 text-azulsecundario font-semibold">Pigmentos</span>
                            <span class="px-4 py-2 rounded-full bg-grisbg text-azulprimario font-semibold">Serigrafía</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Valores -->
        <section class="py-12">
            
            <div class="max-w-7xl mx-auto px-4">
                <Badge text="FORTALEZAS"/>
                <div class="grid md:grid-cols-4 gap-8 mt-20">
                    <!-- Innovación Tecnológica -->
                    <div class="text-center">
                        <div class="w-20 h-20 bg-azulprimario rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/>
                            </svg>
                        </div>
                        <h3 class="font-bold text-azulprimario text-lg mb-3">Innovación Tecnológica</h3>
                        <p class="text-gray-600 text-sm">
                            Desarrollo constante de nuevas fórmulas y tecnologías en tintas textiles para ofrecer soluciones avanzadas y competitivas.
                        </p>
                    </div>

                    <!-- Sostenibilidad Ambiental -->
                    <div class="text-center">
                        <div class="w-20 h-20 bg-azulprimario rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg class="w-10 h-10" viewBox="0 -960 960 960" fill="white"><path d="M216-176q-45-45-70.5-104T120-402q0-63 24-124.5T222-642q35-35 86.5-60t122-39.5Q501-756 591.5-759t202.5 7q8 106 5 195t-16.5 160.5q-13.5 71.5-38 125T684-182q-53 53-112.5 77.5T450-80q-65 0-127-25.5T216-176Zm112-16q29 17 59.5 24.5T450-160q46 0 91-18.5t86-59.5q18-18 36.5-50.5t32-85Q709-426 716-500.5t2-177.5q-49-2-110.5-1.5T485-670q-61 9-116 29t-90 55q-45 45-62 89t-17 85q0 59 22.5 103.5T262-246q42-80 111-153.5T534-520q-72 63-125.5 142.5T328-192Zm0 0Zm0 0Z"/></svg>
                        </div>
                        <h3 class="font-bold text-azulprimario text-lg mb-3">Sostenibilidad Ambiental</h3>
                        <p class="text-gray-600 text-sm">
                            Compromiso con productos ecológicos para un futuro sustentable.
                        </p>
                    </div>

                    <!-- Calidad y Excelencia -->
                    <div class="text-center">
                        <div class="w-20 h-20 bg-azulprimario rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                            </svg>
                        </div>
                        <h3 class="font-bold text-azulprimario text-lg mb-3">Calidad y Excelencia</h3>
                        <p class="text-gray-600 text-sm">
                            Productos de alta calidad y durabilidad con control riguroso en todos nuestros procesos de fabricación.
                        </p>
                    </div>

                    <!-- Confiabilidad y Servicio -->
                    <div class="text-center">
                        <div class="w-20 h-20 bg-azulprimario rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"/>
                            </svg>
                        </div>
                        <h3 class="font-bold text-azulprimario text-lg mb-3">Confiabilidad y Servicio</h3>
                        <p class="text-gray-600 text-sm">
                            25+ años de experiencia brindando soporte técnico especializado y relaciones duraderas con nuestros clientes.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Objetivo y Misión -->
        <section class="py-0">
            <!-- Objetivo -->
            <div class="relative w-full h-64 md:h-80 lg:h-96 overflow-hidden">
                <!-- Imagen de fondo -->
                <Image 
                    src={objetivo} 
                    alt="Objetivo - Industrias Polyvac" 
                    class="absolute inset-0 w-full h-full object-cover"
                />
                <!-- Overlay con gradiente -->
                <div class="absolute inset-0 bg-gradient-to-r from-blue-900/95 via-blue-900/80 to-black/50"></div>
                
                <!-- Contenido -->
                <div class="relative z-10 h-full flex items-center">
                    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
                        <div class="max-w-xl">
                            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4 sm:mb-6">
                                OBJETIVO
                                <div class="w-16 h-1 bg-white mt-2"></div>
                            </h2>
                            <p class="text-white text-base text-sm lg:text-xl leading-relaxed">
                                Ofrecer productos y servicio de óptimo costo-eficiencia, ecológicamente amigables y que se desempeñen consistentemente en forma satisfactoria a través de la eficiente utilización de la tecnología con alta productividad y calidad para apoyar el desarrollo de nuestros clientes.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Misión -->
            <div class="relative w-full h-64 md:h-80 lg:h-96 overflow-hidden mt-4">
                <!-- Imagen de fondo -->
                <Image 
                    src={mision} 
                    alt="Misión - Industrias Polyvac" 
                    class="absolute inset-0 w-full h-full object-cover"
                />
                <!-- Overlay con gradiente -->
                <div class="absolute inset-0 bg-gradient-to-l from-gray-900/95 via-gray-900/80 to-black/50"></div>
                
                <!-- Contenido -->
                <div class="relative z-10 h-full flex items-center">
                    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
                        <div class="max-w-xl ml-auto text-right">
                            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4 sm:mb-6">
                                MISIÓN
                                <div class="w-16 h-1 bg-white mt-2 ml-auto"></div>
                            </h2>
                            <p class="text-white text-base text-sm lg:text-xl leading-relaxed">
                                Mejorar de manera continua el valor y confiabilidad de nuestros productos y servicios mediante la innovación, la participación creativa y el compromiso de todos los empleados, ejecutivos y accionistas de nuestra empresa, contando en este proceso con la participación activa de nuestros clientes y proveedores.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Certificaciones -->
        <section class="py-16 mt-15 overflow-hidden">
            <div class="mb-12 px-4">
                <h2 class="text-4xl md:text-5xl font-bold text-center mb-4 bg-gradient-to-r from-green-500 via-blue-500 to-red-500 bg-clip-text text-transparent">
                    CERTIFICACIONES Y NORMAS
                </h2>
                <p class="text-center text-lg md:text-xl font-medium max-w-3xl mx-auto bg-gradient-to-r from-gray-600 to-gray-800 bg-clip-text text-transparent">
                    Todos nuestros productos cumplen con las normas requeridas por:
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-0">
                <!-- OEKOTEX 2024 - Verde -->
                <div class="relative py-16 px-8 text-center min-h-[450px] flex flex-col justify-center items-center transition-all duration-300 hover:scale-105">
                    <div class="absolute inset-0 bg-gradient-to-br from-green-400 via-green-500 to-emerald-600 opacity-85"></div>

                    <div class="relative z-10">
                        <div class="w-40 h-40 bg-white rounded-2xl flex items-center justify-center mx-auto mb-6 p-6 shadow-2xl transform transition-transform hover:rotate-3">
                            <Image
                                src={oekotexLogo}
                                alt="Logo OEKOTEX 2024"
                                class="w-full h-full object-contain"
                            />
                        </div>
                        <h3 class="text-3xl font-bold text-white mb-2 drop-shadow-lg">OEKOTEX</h3>
                        <h4 class="text-2xl font-bold text-green-100 mb-4">2024</h4>
                        <p class="text-base text-white max-w-xs mx-auto drop-shadow-md">
                            Estándar internacional para textiles libres de sustancias nocivas
                        </p>
                    </div>
                </div>

                <!-- BLUESIGN - Azul -->
                <div class="relative py-16 px-8 text-center min-h-[450px] flex flex-col justify-center items-center transition-all duration-300 hover:scale-105">
                    <div class="absolute inset-0 bg-gradient-to-br from-blue-400 via-blue-600 to-indigo-700 opacity-85"></div>

                    <div class="relative z-10">
                        <div class="w-40 h-40 bg-white rounded-2xl flex items-center justify-center mx-auto mb-6 p-6 shadow-2xl transform transition-transform hover:rotate-3">
                            <Image
                                src={bluesignLogo}
                                alt="Logo Bluesign"
                                class="w-full h-full object-contain"
                            />
                        </div>
                        <h3 class="text-3xl font-bold text-white mb-2 drop-shadow-lg">BLUESIGN</h3>
                        <h4 class="text-2xl font-bold text-blue-100 mb-4">APPROVED</h4>
                        <p class="text-base text-white max-w-xs mx-auto drop-shadow-md">
                            Sistema de gestión para una producción textil sostenible
                        </p>
                    </div>
                </div>

                <!-- BUREAU VERITAS - Rojo -->
                <div class="relative py-16 px-8 text-center min-h-[450px] flex flex-col justify-center items-center transition-all duration-300 hover:scale-105">
                    <div class="absolute inset-0 bg-gradient-to-br from-red-400 via-red-600 to-rose-700 opacity-85"></div>

                    <div class="relative z-10">
                        <div class="w-40 h-40 bg-white rounded-2xl flex items-center justify-center mx-auto mb-6 p-6 shadow-2xl transform transition-transform hover:rotate-3">
                            <Image
                                src={bureauVeritasLogo}
                                alt="Logo Bureau Veritas"
                                class="w-full h-full object-contain"
                            />
                        </div>
                        <h3 class="text-3xl font-bold text-white mb-2 drop-shadow-lg">BUREAU</h3>
                        <h4 class="text-3xl font-bold text-red-100 mb-4">VERITAS</h4>
                        <p class="text-base text-white max-w-xs mx-auto drop-shadow-md">
                            Líder mundial en servicios de inspección, certificación y ensayos
                        </p>
                    </div>
                </div>
            </div>
        </section>
    </div>
</Layout>
