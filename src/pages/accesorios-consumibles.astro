---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
import products from "../data/accesorios-consumibles.js";
import cubetaImage from '../assets/cubeta.png';

// Importar imágenes
import bannerImage from '../assets/hero/test.png';

const title = "Accesorios y Consumibles - Industrias Polyvac";

const sections = [
  { id: 'mallas', title: 'Mallas de Poliéster 100%', familia: 'mallas' }
];
---

<Layout title={title} description="Mallas de poliéster, herramientas y materiales consumibles para serigrafía profesional. Accesorios de calidad para estampado textil.">
    <PageBanner 
        imageUrl={bannerImage}
        titulo="Accesorios y Consumibles"
    />
    
    <div class="container mx-auto px-4 py-12">
        <div class="max-w-7xl mx-auto space-y-16">
            <p class="text-lg text-gray-700 text-center mb-10 max-w-3xl mx-auto">
                Encuentra todo lo necesario para tu taller de serigrafía. Desde mallas de alta tensión hasta químicos de limpieza.
            </p>

            {sections.map((section) => {
                const sectionProducts = products.filter(p => p.familia === section.familia);
                
                return (
                    <section id={section.id} class="scroll-mt-24">
                        <div class="flex items-center gap-4 mb-8">
                            <h2 class="text-2xl md:text-3xl font-bold text-azulsecundario">{section.title}</h2>
                            <div class="h-1 flex-grow bg-gray-200 rounded-full"></div>
                        </div>

                        {sectionProducts.length > 0 ? (
                             <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                                {sectionProducts.map((producto) => (
                                    <a 
                                        href={`/producto/${producto.id}`}
                                        class="group block bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-all hover:-translate-y-1 overflow-hidden"
                                    >
                                        <div class="relative aspect-square p-2 bg-gray-50 flex items-center justify-center">
                                            <div 
                                                class="absolute top-0 right-0 w-16 h-16 bg-azulprimario/10 rounded-bl-full -mr-8 -mt-8 transition-transform group-hover:scale-150"
                                            ></div>
                                            
                                            <Image 
                                                src={producto.imagenes && producto.imagenes.length > 0 ? producto.imagenes[0] : cubetaImage} 
                                                alt={producto.titulo}
                                                class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-300"
                                                width={300}
                                                height={300}
                                            />
                                            
                                            {/* Etiqueta flotante */}
                                            {producto.items && producto.items[0] && (
                                                <div class="absolute bottom-3 left-3 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-semibold text-azulprimario border border-blue-100 shadow-sm">
                                                    {producto.items[0].nombre}
                                                </div>
                                            )}
                                        </div>

                                        <div class="p-5">
                                            <h3 class="font-bold text-gray-800 text-lg mb-2 group-hover:text-azulprimario transition-colors">
                                                {producto.titulo}
                                            </h3>
                                            <p class="text-sm text-gray-500 line-clamp-2 mb-4">
                                                {producto.descripcion}
                                            </p>
                                            <span class="inline-flex items-center text-sm font-medium text-azulprimario group-hover:underline">
                                                Ver especificaciones
                                                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                                            </span>
                                        </div>
                                    </a>
                                ))}
                             </div>
                        ) : (
                            <div class="bg-gray-50 rounded-lg p-8 text-center border-2 border-dashed border-gray-200">
                                <p class="text-gray-500 italic">No hay productos disponibles en esta categoría por el momento.</p>
                            </div>
                        )}
                    </section>
                );
            })}
        </div>
    </div>
</Layout>
