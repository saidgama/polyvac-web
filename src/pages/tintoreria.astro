---
import Layout from "../layouts/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
import Badge from "../components/Badge.astro";
import products from "../data/tintoreria.js";

// Importar imágenes
import bannerImage from '../assets/cardTintoreria.png';
import quimicosBannerA from '../assets/tintoreria/bannerA.jpeg';
import quimicosBannerB from '../assets/tintoreria/bannerB.jpeg';
import quimicosBannerC from '../assets/tintoreria/bannerC.jpeg';

const title = "Tintorería - Industrias Polyvac";

const colors = [
    '#2563EB', // Blue
    '#DC2626', // Red
    '#16A34A', // Green
    '#D97706', // Amber
    '#9333EA', // Purple
    '#0891B2', // Cyan
    '#DB2777', // Pink
    '#4F46E5', // Indigo
];

// Filtrar productos de la subcategoría Químicos Auxiliares y asignar color aleatorio
const quimicosAuxiliares = products
    .filter(p => p.subcategoria === "quimicos-auxiliares")
    .sort((a, b) => a.titulo.localeCompare(b.titulo))
    .map(p => ({
        ...p,
        colorPrincipal: colors[Math.floor(Math.random() * colors.length)]
    }));

const initialCount = 4;
---

<Layout title={title} description="Químicos auxiliares para tintorería y procesos de teñido textil industrial. Productos de alta calidad para acabados profesionales.">
    <PageBanner 
        imageUrl={bannerImage}
        titulo="Tintorería"
    />
    
    <div class="container mx-auto px-4 py-16 min-h-[50vh]">
        
        <!-- Subcategoría: Químicos Auxiliares -->
        <section id="quimicos-auxiliares" class="mb-16">
            <div class="relative mb-10">
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-0 rounded-2xl overflow-hidden border border-gray-200">
                    <img src={quimicosBannerC.src} alt="Químicos auxiliares - banner 1" class="h-44 sm:h-56 w-full object-cover" loading="lazy" />
                    <img src={quimicosBannerB.src} alt="Químicos auxiliares - banner 2" class="h-44 sm:h-56 w-full object-cover" loading="lazy" />
                    <img src={quimicosBannerA.src} alt="Químicos auxiliares - banner 3" class="h-44 sm:h-56 w-full object-cover" loading="lazy" />
                </div>
                <div class="absolute top-0 left-0 -translate-x-4 -translate-y-8 z-10 badge-tight">
                    <Badge text="Químicos Auxiliares" />
                </div>
            </div>

            <div class="flex flex-col md:flex-row items-center justify-between mb-8 gap-4 border-b border-gray-200 pb-4">
                <div class="flex items-center gap-3">
                    <span class="bg-blue-100 text-azulprimario text-sm font-bold px-3 py-1 rounded-full">{quimicosAuxiliares.length} productos</span>
                </div>
                
                <button id="top-toggle-btn" class="text-azulprimario hover:text-blue-800 font-semibold flex items-center gap-2 transition-colors">
                    <span class="toggle-text">Ver todos</span>
                    <svg class="w-5 h-5 transition-transform duration-300 toggle-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </button>
            </div>

            <!-- Grid de productos -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="quimicos-grid">
                {quimicosAuxiliares.map((product, index) => (
                    <div class={`bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden relative flex flex-col hover:shadow-md transition-all duration-300 group ${index >= initialCount ? 'hidden product-card-hidden' : ''}`}>
                         
                        {/* Polígono con el título */}
                        <div class="pt-6 px-4">
                            <div 
                                class="px-5 py-2.5 flex items-center justify-center w-full"
                                style={`background-color: ${product.colorPrincipal || '#2563EB'}; opacity: 0.9; clip-path: polygon(0 0, calc(100% - 15px) 0, 100% 50%, calc(100% - 15px) 100%, 0 100%);`}
                            >
                                <div class="text-center pr-4"> 
                                    <span class="text-white text-sm font-bold leading-tight">{product.titulo}</span>
                                </div>
                            </div>
                        </div>

                        {/* Descripción */}
                        <div class="flex-1 px-5 py-3">
                            <p class="text-gray-600 text-xs leading-relaxed line-clamp-5">{product.descripcion}</p>
                        </div>

                         <div class="px-5 pb-5">
                             <a 
                                href={product.fichaTecnica} 
                                target="_blank" 
                                class="block w-full"
                                title="Descargar Ficha Técnica"
                            >
                                <button class="w-full bg-azulprimario text-white py-2.5 rounded-lg font-semibold text-sm hover:bg-blue-700 hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0 transition-all flex items-center justify-center gap-2">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                                    Ficha Técnica
                                </button>
                            </a>
                        </div>
                    </div>
                ))}
            </div>

            <!-- Botón inferior desplegar -->
            <div class="mt-12 text-center">
                <button id="bottom-toggle-btn" class="group relative inline-flex items-center justify-center overflow-hidden rounded-full bg-white border-2 border-azulprimario px-8 py-3 font-medium text-azulprimario shadow-sm hover:bg-azulprimario hover:text-white transition-all duration-300">
                    <span class="mr-2 toggle-text">Ver todos los productos</span>
                    <svg class="w-5 h-5 transition-transform toggle-icon group-hover:translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </button>
            </div>
        </section>

    </div>
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const topBtn = document.getElementById('top-toggle-btn');
        const bottomBtn = document.getElementById('bottom-toggle-btn');
        const hiddenCards = document.querySelectorAll('.product-card-hidden');
        const toggleTexts = document.querySelectorAll('.toggle-text');
        const toggleIcons = document.querySelectorAll('.toggle-icon');
        
        let isExpanded = false;

        function toggleProducts() {
            isExpanded = !isExpanded;
            
            // Toggle visibilidad
            hiddenCards.forEach(card => {
                card.classList.toggle('hidden');
                if(!card.classList.contains('hidden')) {
                    card.classList.add('animate-fade-in');
                }
            });

            // Actualizar textos y botones
            toggleTexts.forEach(span => {
                span.textContent = isExpanded ? 'Mostrar menos' : 'Ver todos los productos';
            });

            // Rotar iconos
            toggleIcons.forEach(icon => {
                if (isExpanded) {
                    icon.classList.add('rotate-180');
                    if (icon.parentElement && icon.parentElement.id === 'bottom-toggle-btn') {
                        icon.classList.remove('group-hover:translate-y-1');
                    }
                } else {
                    icon.classList.remove('rotate-180');
                }
            });

            // Si colapsamos, scrollear al inicio de la lista
            if (!isExpanded) {
                const section = document.getElementById('quimicos-auxiliares');
                if (section) section.scrollIntoView({ behavior: 'smooth' });
            }
        }

        if(topBtn) topBtn.addEventListener('click', toggleProducts);
        if(bottomBtn) bottomBtn.addEventListener('click', toggleProducts);
    });
</script>

<style>
    .animate-fade-in {
        animation: fadeIn 0.5s ease-out forwards;
    }

    .badge-tight :global(div) {
        margin: 0;
    }
    
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
