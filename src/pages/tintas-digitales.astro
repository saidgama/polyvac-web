---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import PageBanner from "../components/PageBanner.astro";
import Badge from "../components/Badge.astro";
import productosData from "../data/productos.js";
import productosEstampado from "../data/estampado.js";
import productosColorantes from "../data/colorantes.js";
import productosEfectos from "../data/efectos-especiales.js";

const productos = [...productosData, ...productosEstampado, ...productosColorantes, ...productosEfectos];

// Importar imágenes
import categoryBanner from '../assets/hero/test.png';
import cubetaImage from '../assets/cubeta.png';

const title = "Tintas Digitales - Industrias Polyvac";
const description = "Tintas de alta calidad para impresión digital textil y sublimación. Soluciones profesionales para producción a gran escala.";

// Función para filtrar productos por taxonomía
function getProductosPorTaxonomia(taxonomiaId: number) {
    return productos.filter(producto => producto.taxonomias?.includes(taxonomiaId));
}

// Datos hardcodeados para las subcategorías y taxonomías de Tintas Digitales
const subcategorias = [
    {
        id: 1,
        nombre: "Tintas de sublimación",
        slug: "tintas-sublimacion",
        descripcion: "Tintas especiales para sublimación sobre poliéster",
        taxonomias: [
            { id: 401, nombre: "Sublimación CMYK", slug: "sublimacion-cmyk" },
            { id: 402, nombre: "Sublimación fluorescente", slug: "sublimacion-fluorescente" }
        ]
    },
    {
        id: 2,
        nombre: "Tintas DTG",
        slug: "tintas-dtg",
        descripcion: "Tintas para impresión directa sobre prendas",
        taxonomias: [
            { id: 403, nombre: "DTG para algodón", slug: "dtg-algodon" },
            { id: 404, nombre: "DTG para oscuros", slug: "dtg-oscuros" },
            { id: 405, nombre: "Pretratamiento", slug: "pretratamiento" }
        ]
    },
    {
        id: 3,
        nombre: "Tintas DTF",
        slug: "tintas-dtf",
        descripcion: "Tintas para transferencia directa a film",
        taxonomias: [
            { id: 406, nombre: "DTF color", slug: "dtf-color" },
            { id: 407, nombre: "DTF blanco", slug: "dtf-blanco" },
            { id: 408, nombre: "Adhesivo DTF", slug: "adhesivo-dtf" }
        ]
    }
];
---

<Layout title={title} description={description}>
    <!-- Banner de página -->
    <PageBanner 
        imageUrl={categoryBanner}
        titulo="Tintas Digitales"
    />

    <!-- Contenido principal -->
    <main class="font-fuenteprincipal">
        {subcategorias.map((subcategoria) => (
            <section id={`categoria-${subcategoria.slug}`} class="py-20 scroll-mt-32">
                <!-- Badge de subcategoría -->
                <Badge text={subcategoria.nombre} />
                
                <!-- Descripción de subcategoría -->
                <div class="mx-auto max-w-7xl px-4 py-6">
                    <p class="text-center text-lg md:text-xl text-azulsecundario max-w-4xl mx-auto">
                        {subcategoria.descripcion}
                    </p>
                </div>

                <!-- Taxonomías -->
                {subcategoria.taxonomias.map((taxonomia) => (
                    <div id={`categoria-${taxonomia.slug}`} class="mx-auto max-w-7xl px-4 py-8 scroll-mt-32">
                        <!-- Título de taxonomía -->
                        <div class="mb-6">
                            <h3 class="text-2xl md:text-3xl font-bold text-azulsecundario mb-2">
                                {taxonomia.nombre}
                            </h3>
                            <div class="w-20 h-1 bg-azulprimario"></div>
                        </div>

                        <!-- Grid de productos -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                                    {(() => {
                                        const productosEnTaxonomia = getProductosPorTaxonomia(taxonomia.id);
                                        
                                        if (productosEnTaxonomia.length === 0) {
                                            return (
                                                <div class="col-span-full text-center py-8">
                                                    <p class="text-gray-500">Próximamente productos disponibles</p>
                                                </div>
                                            );
                                        }
                                        
                                        return productosEnTaxonomia.map((producto: any) => (
                                            <a 
                                                href={`/producto/${producto.id}`}
                                                class="product-card block p-3 rounded-lg shadow-md border border-gray-200 hover:shadow-lg transition-shadow bg-white cursor-pointer"
                                            >
                                                <div class="relative h-48 bg-gray-100 rounded mb-2 flex items-center justify-center overflow-hidden">
                                                    <Image 
                                                        src={producto.imagenes?.[0] ?? cubetaImage} 
                                                        alt={producto.titulo}
                                                        class="w-full h-full object-cover"
                                                        width={533}
                                                        height={492}
                                                        loading="lazy"
                                                    />
                                                    {producto.colorPrincipal && (
                                                        <div 
                                                            class="absolute bottom-0 left-0 px-4 py-2 z-10 flex items-center justify-center min-w-[120px]"
                                                            style={`background-color: ${producto.colorPrincipal}; opacity: 0.9; clip-path: polygon(0 0, calc(100% - 15px) 0, 100% 50%, calc(100% - 15px) 100%, 0 100%);`}
                                                        >
                                                            <div class="text-center">
                                                                <span class="text-white text-sm font-bold leading-tight">{producto.titulo}</span>
                                                            </div>
                                                        </div>
                                                    )}
                                                </div>
                                                <p class="text-sm mb-3 line-clamp-6 text-gray-600">
                                                    {producto.descripcion}
                                                </p>
                                                <div class="w-full py-2 rounded text-center text-sm font-medium transition-colors bg-azulprimario text-white hover:bg-blue-700">
                                                    Ver detalles
                                                </div>
                                            </a>
                                        ));
                                    })()}
                        </div>
                    </div>
                ))}
            </section>
        ))}
    </main>

    <style>
        .product-card {
            min-height: 320px;
        }

        .line-clamp-6 {
            display: -webkit-box;
            -webkit-line-clamp: 6;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
    </style>
</Layout>
