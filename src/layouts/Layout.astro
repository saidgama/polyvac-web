---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { contactInfo } from '../data/contacto.js';

const { title, description } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        
        <!-- Open Graph -->
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:locale" content="es_MX" />
        <meta property="og:site_name" content="Industrias Polyvac" />
        
        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        
        <!-- Google Fonts (non-blocking) -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap" />
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap" media="print" onload="this.media='all'" />
        <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap" /></noscript>
        
        <!-- Favicon -->
        <link rel="icon" type="image/png" href="/favicon.png" />
        <link rel="shortcut icon" type="image/png" href="/favicon.png" />
        <link rel="apple-touch-icon" href="/favicon.png" />


        <script defer src="https://cloud.umami.is/script.js" data-website-id="61a85d24-a08e-412d-9499-65ef65f2ac31"></script>
        
        <!-- Structured Data -->
        <script type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "Organization",
            "name": "Industrias Polyvac S.A. de C.V.",
            "url": "https://polyvac.mx",
            "telephone": "+525559543369",
            "email": "pedidos@polyvac.mx",
            "foundingDate": "1998",
            "description": "Fabricante y distribuidor de colorantes, tintas, pigmentos y productos químicos para la industria textil y serigrafía en México.",
            "address": {
                "@type": "PostalAddress",
                "streetAddress": "Luis Pasteur No. 60, Complejo Industrial Cuamatla",
                "addressLocality": "Cuautitlán Izcalli",
                "addressRegion": "Estado de México",
                "postalCode": "54730",
                "addressCountry": "MX"
            },
            "sameAs": [
                "https://www.facebook.com/p/Industrias-Polyvac-100042747596287/"
            ]
        })} />
    </head>
    <body class="bg-gray-200">
        <Header />
        <slot />
        <Footer />
        
        <!-- WhatsApp Flotante -->
        <a 
            href={contactInfo.whatsapp.href}
            target="_blank"
            rel="noopener noreferrer"
            class="whatsapp-float"
            aria-label="Contactar por WhatsApp"
        >
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span>Contacto</span>
        </a>
        
        <!-- Scripts globales -->
        <script src="/js/search-client.js" is:inline></script>
    </body>
</html>

<style>
    .whatsapp-float {
        position: fixed;
        width: auto;
        height: 60px;
        bottom: 30px;
        right: 30px;
        background-color: #11b05e;
        color: #FFF;
        border-radius: 50px;
        text-align: center;
        font-size: 18px;
        font-weight: 600;
        box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.3);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 0 24px;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .whatsapp-float i {
        font-size: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .whatsapp-float span {
        line-height: 1;
    }

    .whatsapp-float:hover {
        background-color: #075e54;
        transform: scale(1.05);
        box-shadow: 2px 2px 15px rgba(0, 0, 0, 0.4);
    }

    /* Responsive adjustments */
    @media screen and (max-width: 768px) {
        .whatsapp-float {
            height: 50px;
            font-size: 16px;
            padding: 0 20px;
            bottom: 20px;
            right: 20px;
            gap: 8px;
        }

        .whatsapp-float i {
            font-size: 28px;
        }
    }
</style>
