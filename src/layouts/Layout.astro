---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <meta name="description" content={description} />
        
        <!-- Favicon -->
        <link rel="icon" type="image/png" href="/favicon.png" />
        <link rel="shortcut icon" type="image/png" href="/favicon.png" />
        <link rel="apple-touch-icon" href="/favicon.png" />
        
        <link href="https://unpkg.com/boxicons@2.0.7/css/boxicons.min.css" rel="stylesheet">
    </head>
    <body class="bg-gray-200">
        <Header />
        <slot />
        <Footer />
        
        <!-- WhatsApp Floating Button -->
        <a 
            href="https://wa.me/525559543369?text=Hola,%20me%20gustaría%20obtener%20más%20información%20sobre%20sus%20productos"
            target="_blank"
            rel="noopener noreferrer"
            class="whatsapp-float"
            aria-label="Contactar por WhatsApp"
        >
            <i class='bx bxl-whatsapp'></i>
            <span>Contacto</span>
        </a>
        
        <!-- Scripts globales -->
        <script src="/js/auth-manager.js" is:inline></script>
        <script src="/js/route-guard.js" is:inline></script>
        <script src="/js/cart-manager.js" is:inline></script>
        <script src="/js/search-client.js" is:inline></script>
    </body>
</html>

<style>
    .whatsapp-float {
        position: fixed;
        width: auto;
        height: 60px;
        bottom: 30px;
        right: 30px;
        background-color: #25d366;
        color: #FFF;
        border-radius: 50px;
        text-align: center;
        font-size: 18px;
        font-weight: 600;
        box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.3);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 0 24px;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .whatsapp-float i {
        font-size: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .whatsapp-float span {
        line-height: 1;
    }

    .whatsapp-float:hover {
        background-color: #128c7e;
        transform: scale(1.05);
        box-shadow: 2px 2px 15px rgba(0, 0, 0, 0.4);
    }

    /* Responsive adjustments */
    @media screen and (max-width: 768px) {
        .whatsapp-float {
            height: 50px;
            font-size: 16px;
            padding: 0 20px;
            bottom: 20px;
            right: 20px;
            gap: 8px;
        }

        .whatsapp-float i {
            font-size: 28px;
        }
    }
</style>
