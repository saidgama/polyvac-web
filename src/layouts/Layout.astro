---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { contactInfo } from '../data/contacto.js';

const { title, description } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        
        <!-- Open Graph -->
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:locale" content="es_MX" />
        <meta property="og:site_name" content="Industrias Polyvac" />
        
        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        
        <!-- Favicon -->
        <link rel="icon" type="image/png" href="/favicon.png" />
        <link rel="shortcut icon" type="image/png" href="/favicon.png" />
        <link rel="apple-touch-icon" href="/favicon.png" />

        
        <script defer src="https://cloud.umami.is/script.js" data-website-id="61a85d24-a08e-412d-9499-65ef65f2ac31"></script>
        <link href="https://unpkg.com/boxicons@2.0.7/css/boxicons.min.css" rel="stylesheet">
        
        <!-- Structured Data -->
        <script type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "Organization",
            "name": "Industrias Polyvac S.A. de C.V.",
            "url": "https://polyvac.mx",
            "telephone": "+525559543369",
            "email": "pedidos@polyvac.mx",
            "foundingDate": "1998",
            "description": "Fabricante y distribuidor de colorantes, tintas, pigmentos y productos químicos para la industria textil y serigrafía en México.",
            "address": {
                "@type": "PostalAddress",
                "streetAddress": "Luis Pasteur No. 60, Complejo Industrial Cuamatla",
                "addressLocality": "Cuautitlán Izcalli",
                "addressRegion": "Estado de México",
                "postalCode": "54730",
                "addressCountry": "MX"
            },
            "sameAs": [
                "https://www.facebook.com/p/Industrias-Polyvac-100042747596287/"
            ]
        })} />
    </head>
    <body class="bg-gray-200">
        <Header />
        <slot />
        <Footer />
        
        <!-- WhatsApp Flotante -->
        <a 
            href={contactInfo.whatsapp.href}
            target="_blank"
            rel="noopener noreferrer"
            class="whatsapp-float"
            aria-label="Contactar por WhatsApp"
        >
            <i class='bx bxl-whatsapp'></i>
            <span>Contacto</span>
        </a>
        
        <!-- Scripts globales -->
        <script src="/js/search-client.js" is:inline></script>
    </body>
</html>

<style>
    .whatsapp-float {
        position: fixed;
        width: auto;
        height: 60px;
        bottom: 30px;
        right: 30px;
        background-color: #25d366;
        color: #FFF;
        border-radius: 50px;
        text-align: center;
        font-size: 18px;
        font-weight: 600;
        box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.3);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 0 24px;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .whatsapp-float i {
        font-size: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .whatsapp-float span {
        line-height: 1;
    }

    .whatsapp-float:hover {
        background-color: #128c7e;
        transform: scale(1.05);
        box-shadow: 2px 2px 15px rgba(0, 0, 0, 0.4);
    }

    /* Responsive adjustments */
    @media screen and (max-width: 768px) {
        .whatsapp-float {
            height: 50px;
            font-size: 16px;
            padding: 0 20px;
            bottom: 20px;
            right: 20px;
            gap: 8px;
        }

        .whatsapp-float i {
            font-size: 28px;
        }
    }
</style>
